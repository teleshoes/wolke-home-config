#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

my $EXEC = basename $0;

my $USAGE = "
  $EXEC -h | --help
    show this message

  $EXEC [OPTS] CMD [ARG ARG..]
    run: term -e \"screen-cmd -d bash -c 'set -x CMD ARG ARG; read'\"

  OPTS
    --ping
      prefix command with `execPing --timeout=60`
    --ping=IPMAGIC_NAME
      prefix command with `execPing --timeout=60 --ipmagic=IPMAGIC_NAME`

    -S SESSION_NAME | -s SESSION_NAME
    --screen-session=SESSION_NAME
      pass '-S SESSION_NAME' to screen-cmd
";

sub main(@){
  my @cmdArgs;
  my $opts = {
    ping        => 0,
    pingIpmagic => undef,
  };
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^--ping$/){
      $$opts{ping} = 1;
    }elsif($arg =~ /^--ping=([a-zA-Z0-9]+)$/){
      $$opts{ping} = 1;
      $$opts{pingIpmagic} = $1;
    }elsif($arg =~ /^(-s|-S)$/ and @_ > 0){
      $$opts{screenSession} = shift @_;
    }elsif($arg =~ /^--screen-session=(\w+)$/){
      $$opts{screenSession} = $1;
    }elsif($arg =~ /^[^-]/){
      #first arg that doesn't start with hyphen is CMD, any other args are ARG
      @cmdArgs = ($arg, @_);
      @_ = ();
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }
  die "$USAGE\nERROR: missing CMD\n" if @cmdArgs == 0;

  if($$opts{ping}){
    my @execPingCmd = ("execPing", "--timeout=60");
    if(defined $$opts{pingIpmagic}){
      push @execPingCmd, "--ipmagic=$$opts{pingIpmagic}";
    }
    @cmdArgs = (@execPingCmd, @cmdArgs);
  }

  if(not defined $ENV{DISPLAY}){
    my $display = `display-guess 2>/dev/null`;
    chomp $display;
    $ENV{DISPLAY} = $display if $display =~ /\S/;
  }

  my $sessionArg = defined $$opts{screenSession} ? "-S $$opts{screenSession}" : "";

  exec "term", "-e", "screen-cmd --attach $sessionArg bash -c 'set -x; @cmdArgs; read'";
}

&main(@ARGV);
