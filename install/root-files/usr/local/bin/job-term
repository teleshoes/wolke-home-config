#!/usr/bin/perl
use strict;
use warnings;

sub main(@){
  my $opts = {
    ping        => 0,
    pingIpmagic => undef,
  };
  while(@_ > 0 and $_[0] =~ /^-/){
    my $arg = shift;
    if($arg =~ /^--ping$/){
      $$opts{ping} = 1;
    }elsif($arg =~ /^--ping=([a-zA-Z0-9]+)$/){
      $$opts{ping} = 1;
      $$opts{pingIpmagic} = $1;
    }
  }
  my $cmd = "@_";

  if($$opts{ping}){
    my $execPing = "execPing --timeout=60";
    if(defined $$opts{pingIpmagic}){
      $execPing .= " --ipmagic=$$opts{pingIpmagic}";
    }
    $cmd = "$execPing $cmd";
  }

  if(not defined $ENV{DISPLAY}){
    my $display = `display-guess 2>/dev/null`;
    chomp $display;
    $ENV{DISPLAY} = $display if $display =~ /\S/;
  }

  exec "term", "-e", "screen-cmd -d bash -c 'set -x; $cmd; read'";
}

&main(@ARGV);
