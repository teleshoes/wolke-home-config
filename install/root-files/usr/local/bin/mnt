#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

sub ensureRoot();
sub parseOpts($@);
sub runCommand($$$);
sub filterPartitions($@);
sub getSelectedPart($$);
sub getInfo($);
sub getMountedNames($);
sub getUnmountedNames($);
sub df();
sub isMountedOn($$);
sub mount($);
sub unmount($);
sub blkidGetPartitions();
sub ensureSize($);
sub udevadm($);
sub partedSize($);
sub getName($);
sub isAllowedFS($);
sub isMntDevice($$);
sub run(@);
sub runFail(@);
sub runFailEcho(@);
sub bashComplete($$);

my $MOUNT_DIR = '/media';
my $MAX_TIMEOUT = 60;
my $DELAY = 1;

my $DEV_TYPE_USB = "usb";
my $DEV_TYPE_CARD = "card";
my $DEV_TYPE_OTHER = "other";

my $EXEC = basename $0;

my $USAGE = "
  $EXEC -h | --help
    show this message

  $EXEC [OPTS] [GET_CMD | ACTION_CMD [NAME] ]
             default is \"-m\"

  Mounts/unmounts partitions for usb, flash, and internal/other storage devices.
    --usb and --card are enabled by default
    --other is disabled by default

  If SUDO_UID and/or SUDO_GID environment variables are present,
    mount all fat, msdos and ntfs partitions with uid and/or gid opts.

  '$EXEC' calls: udevadm, blkid, parted, mount, umount, lsof, fuser

  $EXEC --bash-complete COMP_LINE COMP_POINT
     print a list of words for bash completion, one per line
     COMP_LINE  - the full cmdline as a string
     COMP_POINT - the cursor position in the cmdline

  ==========
  GET_CMD:
    -g  for all partitions, print 'NAME size {mounted} dev'
    -n  print 'NAME' of all UNMOUNTED partitions

  ACTION_CMD:
    -m  mount all partitions {or just NAME} at /media
        mount point is the same as NAME
    -u  unmount all partitions {or just NAME}
    -l  check every ${DELAY}s until any partition {or just NAME} is available
          and unmounted, and then mount all partitions

  NAME:
    the partition label if blkid finds one
    OR <devname>  or  <devname>_<size>GiB
       if the device is /dev/<devname> and <devname> is alphanumeric
       <size> is the size in GiB, truncated to tenths, if udev reports it
    OR uuid otherwise

  OPTS:
    --usb --no-usb
    --card --no-card
    --other --no-other
        (default is --usb --card --no-other)
      include or disclude devices of the indicated type, overriding default
  ==========
";

my $CMD_MOUNT = "mount";
my $CMD_UMOUNT = "umount";
my $CMD_GET = "get";
my $CMD_GET_NAMES = "get-names";
my $CMD_LAZY_MOUNT = "lazy-mount";

sub main(@){
  if(@_ == 3 and $_[0] =~ /^--bash-complete$/ and $_[2] =~ /^\d+$/){
    print map {"$_\n"} bashComplete($_[1], $_[2]);
    exit 0;
  }

  ensureRoot();

  my ($cmd, $name, $opts) = parseOpts(1, @_);

  runCommand $cmd, $name, $opts;
}

sub ensureRoot(){
  if(`whoami` ne "root\n"){
    print STDERR "rerunning as root\n";
    exec "sudo", $0, @ARGV;
  }
}

sub parseOpts($@){
  my ($validate, @args) = @_;

  my $cmd = $CMD_MOUNT;
  my $name = undef;
  my $opts = {
    includeUsb   => 1,
    includeCard  => 1,
    includeOther => 0,
  };

  while(@args > 0){
    my $arg = shift @args;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(-m)$/){
      $cmd = $CMD_MOUNT;
    }elsif($arg =~ /^(-u)$/){
      $cmd = $CMD_UMOUNT;
    }elsif($arg =~ /^(-g)$/){
      $cmd = $CMD_GET;
    }elsif($arg =~ /^(-n)$/){
      $cmd = $CMD_GET_NAMES;
    }elsif($arg =~ /^(-l)$/){
      $cmd = $CMD_LAZY_MOUNT;
    }elsif($arg =~ /^(--usb)$/){
      $$opts{includeUsb} = 1;
    }elsif($arg =~ /^(--no-usb)$/){
      $$opts{includeUsb} = 0;
    }elsif($arg =~ /^(--card)$/){
      $$opts{includeCard} = 1;
    }elsif($arg =~ /^(--no-card)$/){
      $$opts{includeCard} = 0;
    }elsif($arg =~ /^(--other)$/){
      $$opts{includeOther} = 1;
    }elsif($arg =~ /^(--no-other)$/){
      $$opts{includeOther} = 0;
    }elsif($cmd =~ /^($CMD_MOUNT|$CMD_UMOUNT|$CMD_LAZY_MOUNT)$/ and not defined $name){
      $name = $arg;
    }else{
      if($validate){
        die "$USAGE\nERROR: unknown arg $arg\n";
      }
    }
  }

  return ($cmd, $name, $opts);
}

sub runCommand($$$){
  my ($cmd, $name, $opts) = @_;

  my @mntParts = blkidGetPartitions();
  @mntParts = filterPartitions($opts, @mntParts);

  if($cmd eq $CMD_MOUNT){
    if(defined $name){
      my $selectedPart = getSelectedPart(\@mntParts, $name);
      die "already mounted\n" if ${$selectedPart}{isMounted};
      mount $selectedPart;
    }else{
      my @unmounted = grep {!${$_}{isMounted}} @mntParts;
      mount $_ foreach @unmounted;
    }
  }elsif($cmd eq $CMD_UMOUNT){
    if(defined $name){
      my $selectedPart = getSelectedPart(\@mntParts, $name);
      die "already unmounted\n" if !${$selectedPart}{isMounted};
      unmount $selectedPart;
    }else{
      my @mounted = grep {${$_}{isMounted}} @mntParts;
      unmount $_ foreach @mounted;
    }
  }elsif($cmd eq $CMD_GET){
    print "$_\n" foreach getInfo \@mntParts;
  }elsif($cmd eq $CMD_GET_NAMES){
    my @unmounted = grep {not $$_{isMounted}} @mntParts;
    print "$$_{name}\n" foreach @unmounted;
  }elsif($cmd eq $CMD_LAZY_MOUNT){
    my @names;
    my $start = time;
    while(@names == 0){
      my @unmounted = grep {not $$_{isMounted}} @mntParts;
      @names = map {$$_{name}} @unmounted;
      @names = grep {$_ eq $name} @names if defined $name;
      if(defined $name){
        print "waiting for $name...\n";
      }else{
        print "waiting for unmounted partitions...\n";
      }
      if(@names == 0){
        die "timeout exceeded\n" if time > ($start+$MAX_TIMEOUT);
        sleep $DELAY;
        @mntParts = blkidGetPartitions();
        @mntParts = filterPartitions($opts, @mntParts);
      }
    }
    print "partition(s) found, mounting\n";
    for my $name(@names){
      runCommand $CMD_MOUNT, $name, $opts;
    }
  }
}

sub filterPartitions($@){
  my ($opts, @partitions) = @_;

  my @okDevTypes;
  push @okDevTypes, $DEV_TYPE_USB if $$opts{includeUsb};
  push @okDevTypes, $DEV_TYPE_CARD if $$opts{includeCard};
  push @okDevTypes, $DEV_TYPE_OTHER if $$opts{includeOther};
  my $devTypeRegex = join "|", @okDevTypes;

  @partitions = grep {$$_{type} ne "swap"} @partitions;

  @partitions = grep {$$_{devType} =~ /^($devTypeRegex)$/} @partitions;

  return @partitions;
}
sub getSelectedPart($$){
  my @mntParts = @{shift()};
  my $name = shift;

  foreach(@mntParts){
    if(${$_}{name} eq $name){
      return $_;
    }
  }
  die "Unknown NAME $name; try '$0 -g'\n";
}

sub getInfo($){
  my @mntParts = @{shift()};
  my @info;
  foreach my $p (@mntParts){
    ensureSize $p;
    my $name = "$$p{name}";
    my $size = defined $$p{sizeGiB} ? " $$p{sizeGiB}GiB" : "";
    my $mounted = $$p{isMounted} ? ' mounted' : ' unmounted';
    my $dev = " $$p{dev}";
    push @info, "$name$size$mounted$dev";
  }
  return @info;
}

sub getMountedNames($){
  my @mntParts = @{shift()};
  my @names;
  foreach my $p (@mntParts){
    if($$p{isMounted}){
      push @names, "$$p{name}";
    }
  }
  return @names;
}
sub getUnmountedNames($){
  my @mntParts = @{shift()};
  my @names;
  foreach my $p (@mntParts){
    if(not $$p{isMounted}){
      push @names, "$$p{name}";
    }
  }
  return @names;
}

sub df(){
  my $df = {};
  my @dfLines = `df`;
  shift @dfLines;
  for my $dfLine(@dfLines){
    if($dfLine =~ /^(.*?)\s+(\d+)\s+(\d+)\s+(\d+)\s+(\d+\%)\s+(.*)$/){
      my ($dev, $blocks, $used, $available, $use, $mountpoint) =
        ($1, $2, $3, $4, $5, $6);
      $$df{$dev} = {} if not defined $$df{$dev};
      $$df{$dev}{$mountpoint} = {
        blocks => $blocks,
        available => $available,
        used => $used,
        use => $use,
      };
    }else{
      die "Invalid df line: $dfLine\n";
    }
  }
  return $df;
}

sub isMountedOn($$){
  my ($dev, $mountPoint) = @_;
  my $df = df();
  return defined $$df{$dev} && defined $$df{$dev}{$mountPoint};
}

sub mount($){
  my %p = %{shift()};
  my $mountPoint = "$MOUNT_DIR/$p{name}";
  if(isMountedOn $p{dev}, $mountPoint){
    print STDERR "$p{dev} already mounted\n";
    return;
  }

  run "rmdir $mountPoint 2>/dev/null";
  if(-e $mountPoint){
    die "$mountPoint exists and is not removable with rmdir";
  }
  runFail "mkdir", $mountPoint;

  my @mntOpts;
  if($p{type} =~ /fat|msdos|ntfs/i){
    push @mntOpts, "uid=$ENV{SUDO_UID}" if defined $ENV{SUDO_UID};
    push @mntOpts, "gid=$ENV{SUDO_GID}" if defined $ENV{SUDO_GID};
  }
  my @mntOptArgs = ();
  @mntOptArgs = ("-o", join ",", @mntOpts) if @mntOpts > 0;

  runFailEcho "mount", "-t", $p{type}, $p{dev}, $mountPoint, @mntOptArgs;
  if(isMountedOn $p{dev}, $mountPoint){
    print "  OK\n";
  }else{
    print STDERR "$p{dev} not mounted on $mountPoint, according to mtab";
    return;
  }
}

sub unmount($){
  my %p = %{shift()};
  my $mountPoint = "$MOUNT_DIR/$p{name}";
  if(!isMountedOn $p{dev}, $mountPoint){
    print STDERR "$p{dev} not mounted on $mountPoint\n";
    return;
  }
  run "lsof", $mountPoint;
  run "fuser", $mountPoint;
  runFailEcho "umount", $mountPoint;
  run "rmdir", $mountPoint if -e $mountPoint;
  runFailEcho "rmdir", $mountPoint if -e $mountPoint;
  if(not -e $mountPoint){
    print "  OK\n";
  }else{
    print STDERR "$mountPoint still exists";
    return;
  }
}

sub blkidGetPartitions(){
  my @partitions;

  my $df = df();
  my @blkidLines = `blkid`;

  for my $line(@blkidLines){
    my %p;
    $p{dev} = $1 if $line =~ /^(.*):/;
    $p{label} = $1 if $line =~ /\WLABEL="([^"]+)"/;
    $p{uuid} = $1 if $line =~ /\WUUID="([^"]+)"/;
    $p{type} = $1 if $line =~ /\WTYPE="([^"]+)"/;

    next if not defined $p{uuid};

    $p{udev} = udevadm $p{dev};

    $p{name} = getName \%p;

    $p{devType} = calculateDevType(\%p);
    $p{isMounted} = defined $$df{$p{dev}} ? 1 : 0;

    push @partitions, \%p;
  }
  return @partitions;
}

sub ensureSize($){
  my $p = shift;
  return if defined $$p{sizeGiB};

  my $size = $$p{udev}{UDISKS_PARTITION_SIZE};
  $size = partedSize $$p{dev} if not defined $size;

  if(defined $size and $size =~ /^\d+$/){
    $$p{sizeGiB} = sprintf "%.1f", $size / 2**30;
  }
}

sub udevadm($){
  my $dev = shift;
  my %udev;
  for my $line(`udevadm info --query=property --name=$dev`){
    if($line =~ /^([a-z0-9_\-]+)=(.*)$/i){
      $udev{$1} = $2;
    }
  }
  return \%udev;
}

sub partedSize($){
  my $dev = shift;
  my $partedOut = `parted -s -m $dev unit B print`;
  if($partedOut =~ /^BYT;\n$dev:(\d+)B/){
    return $1;
  }
}

sub getName($){
  my $p = shift;

  if(defined $$p{label} and length $$p{label} > 0){
    return $$p{label};
  }

  my $dev = $$p{dev};
  $dev = '' if not defined $dev;
  if($dev =~ /^\/dev\/([a-z0-9]+)$/i){
    my $devName = $1;
    ensureSize $p;
    if(defined $$p{sizeGiB}){
      return "${devName}_$$p{sizeGiB}GiB";
    }else{
      return $devName;
    }
  }

  return $$p{uuid};
}

sub calculateDevType($){
  my ($partition) = @_;
  my %udev = %{$$partition{udev}};

  my $idPath = $udev{ID_PATH};
  my $isUsbPath = (defined $idPath and $idPath =~ /-usb-/) ? 1 : 0;

  my @flashFlags = qw(
    ID_DRIVE_FLASH_SD
    ID_DRIVE_MEDIA_FLASH_SD
    ID_DRIVE_FLASH_MS
  );
  my $isFlashFlag = 0;
  for my $flag(@flashFlags){
    if(defined $udev{$flag} and $udev{$flag}){
      $isFlashFlag = 1;
      last;
    }
  }

  if($isUsbPath){
    return $DEV_TYPE_USB;
  }elsif($isFlashFlag){
    return $DEV_TYPE_CARD;
  }else{
    return $DEV_TYPE_OTHER;
  }
}

sub run(@){
  system @_;
}
sub runFail(@){
  run @_;
  die "Command failed: @_\n" if $? != 0;
}
sub runFailEcho(@){
  print "@_\n";
  runFail @_;
}

sub bashComplete($$){
  my ($cmdLine, $pos) = @_;
  my $cmdStr = substr $cmdLine, 0, $pos;
  my $isNewWord = $cmdStr =~ /\s$/;
  $cmdStr =~ s/^\s+//;
  $cmdStr =~ s/\s+$//;

  my @words = split /\s+/, $cmdStr;
  shift @words;

  my $curWord = "";
  $curWord = pop @words if not $isNewWord;

  my @opts = qw(
    --usb --no-usb
    --card --no-card
    --other --no-other
  );
  my @cmds = qw(-m -u -g -n -l);

  my $hasOpts = 0;
  my $hasCmds = 0;
  my $regexOpts = join "|", @opts;
  my $regexCmds = join "|", @cmds;
  for my $word(@words){
    $hasOpts = 1 if $word =~ /^($regexOpts)$/;
    $hasCmds = 1 if $word =~ /^($regexCmds)$/;
  }

  my ($cmd, $name, $opts) = parseOpts(0, @words);

  #fetch+filter names with blkid/udevadm/df/etc
  my @names;
  if(not defined $name){
    my @partitions;
    if($cmd =~ /^($CMD_MOUNT|$CMD_LAZY_MOUNT)$/){
      @partitions = filterPartitions($opts, blkidGetPartitions());
      @partitions = grep {not $$_{isMounted}} @partitions;
    }elsif($cmd =~ /^($CMD_UMOUNT)$/){
      @partitions = filterPartitions($opts, blkidGetPartitions());
      @partitions = grep {$$_{isMounted}} @partitions;
    }

    @names = map {$$_{name}} @partitions;
  }

  if($curWord =~ /^-/){
    return (@opts, @cmds);
  }elsif($hasCmds){
    return @names;
  }elsif($hasOpts){
    return (@cmds, @names);
  }else{
    return (@opts, @cmds, @names);
  }
}

&main(@ARGV);
