#!/usr/bin/perl
use strict;
use warnings;
use lib `dirname $0 | tr -d '\n'`;
use ScriptScript;

sub main(@) {
  #copy clearlooks from PySolFC
  installFromGit "https://github.com/shlomif/PySolFC", sub{
    my ($dir) = @_;
    run("rsync", "-avP", "--del",
      "$dir/data/themes/clearlooks/",
      getHome() . "/.local/share/tk-themes/clearlooks/",
    );
  };

  #install Clearlooks-Phenix gtk theme
  installFromGit "https://github.com/jpfleury/clearlooks-phenix", sub{
    my ($dir) = @_;
    run("sudo", "rsync", "-avP", "--del",
      "$dir/",
      "/usr/share/themes/Clearlooks-Phenix/",
    );
  };
}

&main(@ARGV);
