#!/usr/bin/perl
use strict;
use warnings;
use lib `dirname $0 | tr -d '\n'`;
use ScriptScript;

my @GLOBAL_PACKAGES = qw(
  bencode.py audioplayer gehomesdk rshell
);

my %VENV_PACKAGE_SETS = (
  pylitterbot => [qw(pylitterbot)],
);
my @VENV_NAMES = sort keys %VENV_PACKAGE_SETS;

my $USAGE = "Usage:
  $0 -h | --help
    show this message

  $0 --list
    list all install names, one per line:
      @GLOBAL_PACKAGES @VENV_NAMES

  $0 [INSTALL_NAME INSTALL_NAME ..]
    -disable global.require-virtualenv pip warning
    -install or upgrade indicated (or all) global pip packages:
      @GLOBAL_PACKAGES
    -install indicated (or all) venv package sets:
      @VENV_NAMES
";

my $MODE_LIST = "list";
my $MODE_INSTALL = "install";

sub main(@) {
  my $mode = $MODE_INSTALL;
  my %okGlobalPkgs = map {$_ => 1} @GLOBAL_PACKAGES;
  my @installNames;
  while(@_ > 0){
    my $arg = shift @_;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(--list)$/){
      $mode = $MODE_LIST;
    }elsif(defined $okGlobalPkgs{$arg} or defined $VENV_PACKAGE_SETS{$arg}){
      push @installNames, $arg;
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  if($mode eq $MODE_LIST){
    print "$_\n" foreach (@GLOBAL_PACKAGES, @VENV_NAMES);
  }elsif($mode eq $MODE_INSTALL){
    @installNames = (@GLOBAL_PACKAGES, @VENV_NAMES) if @installNames == 0;

    run "pip", "config", "set", "global.require-virtualenv", "False";

    for my $installName(@installNames){
      if(defined $okGlobalPkgs{$installName}){
        run "pip", "install", "--break-system-packages", "--upgrade", $installName;
      }elsif(defined $VENV_PACKAGE_SETS{$installName}){
        my $venvDir = "/opt/$installName-venv";
        my @pkgs = @{$VENV_PACKAGE_SETS{$installName}};

        runSudo "rm", "-rf", $venvDir;
        runSudo "python3", "-m", "venv", $venvDir;
        for my $pkg(@pkgs){
          runSudo "$venvDir/bin/pip", "install", $pkg;
        }
      }else{
        die "ERROR: invalid INSTALL_NAME $installName\n";
      }
    }
  }else{
    die "ERROR: unknown mode $mode\n";
  }
}

&main(@ARGV);
