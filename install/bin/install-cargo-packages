#!/usr/bin/perl
use strict;
use warnings;
use lib `dirname $0 | tr -d '\n'`;
use ScriptScript;

sub install($);

my @CARGO_PACKAGES = qw(
  android-xml-converter
);

my $USAGE = "Usage:
  $0 -h | --help
    show this message

  $0 --list
    print each install, one per line

  $0 [PKG PKG..]
    install selected cargo packages (or all):
      @CARGO_PACKAGES
";

my $MODE_LIST = "list";
my $MODE_INSTALL = "install";

sub main(@) {
  my $mode = $MODE_INSTALL;
  my %okPackages = map {$_ => 1} @CARGO_PACKAGES;
  my @pkgs;
  while(@_ > 0){
    my $arg = shift @_;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(--list)$/){
      $mode = $MODE_LIST;
    }elsif(defined $okPackages{$arg}){
      push @pkgs, $arg;
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  @pkgs = @CARGO_PACKAGES if @pkgs == 0;

  if($mode eq $MODE_LIST){
    print "$_\n" foreach @CARGO_PACKAGES;
  }elsif($mode eq $MODE_INSTALL){
    for my $pkg(@pkgs){
      run "cargo", "install", $pkg;
    }
  }else{
    die "ERROR: unknown mode $mode\n";
  }
}

&main(@ARGV);
