#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);
use Time::HiRes qw(stat);

sub handleFile($$$);
sub exifEpoch($);
sub exifGetDateAsEpochCmdExif($);
sub exifGetDateAsEpochCmdExiftool($);
sub getDuration($);
sub mtimeEpoch($);
sub filenameEpoch($$);
sub isCmdAvail($);
sub convertDateFmtToEpoch($);
sub convertEpochToDateFmt($$);
sub readProc(@);
sub run(@);

my @EXTS_PICTURES = qw(
  jpg jpeg png gif mpo heic
);
my @EXTS_VIDEOS = qw(
  avi m2ts mts mov mkv mpeg mpg mp4
  flv mpv wmv webm
);

my @EXTS_ALL = (@EXTS_PICTURES, @EXTS_VIDEOS);
my $REGEX_EXTS_VIDEOS = "(?:" . (join "|", @EXTS_VIDEOS) . ")";
my $REGEX_EXTS_ALL = "(?:" . (join "|", @EXTS_ALL) . ")";

my $PREFIX_REGEX = "IMG_|VID_|PXL_|SGCAM_";

my $ACTION_RENAME = "rename";
my $ACTION_TOUCH = "touch";
my $ACTION_PRINT = "print";

my $FILE_TZ_MODE_UTC = "utc";
my $FILE_TZ_MODE_LOCAL = "local";

my $FILENAME_MATCH_S = 10;

my $EXEC = basename $0;

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC [OPTS] FILE [FILE FILE ...]
    rename, touch, or print info about files, using exif data, mtime, or filename
      -default action is to rename
      -default timestamp mode is to use exif for JPEG, and mtime otherwise
    FILE must end in '.' followed by one of: @EXTS_ALL
      (see --no-check-ext)

      for each FILE:
        -parse FILE_PREFIX and FILE_SUFFIX
          -get FILENAME as in `basename FILE`
          -if FILE starts with one of '$PREFIX_REGEX':
            -use that as FILE_PREFIX and the rest as FILE_SUFFIX
          -otherwise:
            -use empty FILE_PREFIX and FILENAME as FILE_SUFFIX
        -parse EXIF_EPOCH and EXIF_MILLIS
          -if FILE ends in '.jpg' or '.jpeg':
            -attempt to parse EXIF_DATE_TIME and EXIF_SUBSECOND_TIME using fast `exif` command
          -if EXIF_DATE_TIME is not found:
            -attempt to parse EXIF_DATE_TIME and EXIF_SUBSECOND_TIME using slow `exiftool` command
          -if EXIF_DATE_TIME is not found:
            -fail with an error and do not touch or rename
          (see: --no-exif)
        -parse MTIME_EPOCH and MTIME_MILLIS
          -get mtime in high resolution using Time::HiRes::stat
          -use as MTIME_EPOCH and MTIME_MILLIS
          (see: --no-mtime)
        -subtract duration mtime/exif if FILE is a video
          -calculate VIDEO_DUR of FILE if FILE is a video
            (see: --no-duration)
          -if VIDEO_DUR is found:
            -subtract VIDEO_DUR from EXIF_EPOCH
            -subtract VIDEO_DUR from MTIME_EPOCH
            -if --subtract-duration-filename is given:
              -subtract VIDEO_DUR from FILENAME_EPOCH
              (filename is usually written when video starts)
        -parse FILENAME_EPOCH and FILENAME_MILLIS
          -if FILE_SUFFIX starts with YYYYMMDD_HHMMSSFFF:
            -treat filename date/time as UTC
            -get FILENAME_EPOCH as in `date --date=<YYYY>-<MM>-<DD>T<HH>:<MM><SS>+00:00 +%s`
            -use FILENAME_MILLIS = <FFF>
          -if FILE_SUFFIX starts with YYYYMMDD_HHMMSS:
            -treat filename date/time as local timezone
            -get FILENAME_EPOCH as in `date --date=<YYYY>-<MM>-<DD>T<HH>:<MM><SS> +%s`
            -treat FILENAME_MILLIS as empty
          -otherwise:
            -treat FILENAME_EPOCH and FILENAME_MILLIS as empty
          (see: --no-filename)
        -select TARGET_EPOCH and TARGET_MILLIS
          -if FILENAME_EPOCH is found:
            -ensure either EXIF_EPOCH or MTIME_EPOCH matches, if present
              -if EXIF_EPOCH is also found:
                -ensure EXIF_EPOCH and FILENAME_EPOCH within ${FILENAME_MATCH_S}s, or fail
                -if FILENAME_MILLIS and EXIF_MILLIS are set:
                  -ensure they match, and fail otherwise
                  -ignore FILENAME_MILLIS, and do not add '_###ms' suffix
              -otherwise, if MTIME_EPOCH is also found:
                -ensure MTIME_EPOCH and FILENAME_EPOCH within ${FILENAME_MATCH_S}s, or fail
            -use TARGET_EPOCH=<FILENAME_EPOCH> and TARGET_MILLIS=<FILENAME_MILLIS>
          -if EXIF_EPOCH is found:
            -use TARGET_EPOCH=<EXIF_EPOCH> and TARGET_MILLIS=<EXIF_MILLIS>
          -if MTIME_EPOCH is found:
            -use TARGET_EPOCH=<MTIME_EPOCH> and TARGET_MILLIS=<MTIME_MILLIS>
        -rename files if --rename (this is the default):
          -get TARGET_EPOCH_FMT as in `date --date=\@TARGET_EPOCH +%Y%m%d_%H%M%S`
          -get TRIMMED_FILE_SUFFIX:
            -start with TRIMMED_FILE_SUFFIX = FILE_SUFFIX
            -if TRIMMED_FILE_SUFFIX starts with *any* YYYYmmdd_HHMMSSFFF or YYYYMMDD_HHMMSS:
              -remove the old date/time, including trailing 0s in TRIMMED_FILE_SUFFIX timestamp
                 (e.g.: 20190716_215902952000.jpg => 20190716_215902_952ms.jpg)
            -if TRIMMED_FILE_SUFFIX starts with the same YYYYMMDD as the TARGET_EPOCH_FMT:
              -remove the old YYYYMMDD
          -get MILLIS_PREFIX as '_<TARGET_MILLIS>ms' if TARGET_MILLIS found, otherwise ''
          -calculate NEW_FILE as:
             <FILE_PREFIX><TARGET_EPOCH_FMT><MILLIS_PREFIX><TRIMMED_FILE_SUFFIX>.<EXT>
          -rename file as in: `mv FILE NEW_FILE`
        -touch files if --touch
          -update file mtime+atime as in `touch FILE --date=\@TARGET_EPOCH`
        -print info if --print
          -do not move or touch files
          -print old and new filenames and mtimes

  OPTS
    --rename       {default}
      rename files using the calculated TARGET_EPOCH
    --touch
      use touch to set the mtime to the calculated TARGET_EPOCH
    --print
      do not perform any action, instead just print old/new filenames+mtimes

    --exif | --exif-only
      same as: --use-exif --no-mtime --no-filename
    --filename | --filename-only
      same as: --use-filename --no-exif --no-mtime
    --mtime | --mtime-only
      same as: --use-mtime --no-exif --no-filename

    --no-exif | --ignore-exif
      -do not parse EXIF/QuickTime data
      -do not compare EXIF_EPOCH and FILENAME_EPOCH
      -do not omit FILENAME_MILLIS (since no EXIF/filename comparison is done)
      -do not use EXIF_EPOCH to name/touch files
   --use-exif:
      (NOTE: this is the default)
      -parse+use EXIF_EPOCH and EXIF_MILLIS

    --no-mtime | --ignore-mtime
      -do not parse file mtime
      -do not compare MTIME_EPOCH and FILENAME_EPOCH
      -do not use MTIME_EPOCH to name/touch files
   --use-mtime:
      (NOTE: this is the default)
      -parse+use MTIME_EPOCH and MTIME_MILLIS

    --no-filename | --ignore-filename
      -do not parse filename timestamp
      -do not compare EXIF_EPOCH and FILENAME_EPOCH
      -do not compare MTIME_EPOCH and FILENAME_EPOCH
      -do not omit FILENAME_MILLIS (since no EXIF/filename comparison is done)
      -do not use FILENAME_EPOCH to name/touch files
   --use-filename:
      (NOTE: this is the default)
     -parse+use FILENAME_EPOCH and FILENAME_MILLIS

    --quiet
      do not print 'skipping rename' or 'skipping touch' messages

    --check-ext
      fail if FILE does not end in '.' followed by one of: @EXTS_ALL
      (this is the default)
    -a | --no-check-ext | --allow-ext
      do NOT fail if FILE does not end in '.' followed by one of: @EXTS_ALL
      any ext (or no ext) is permitted
      (files ending in .jpg or .jpeg still use exif mode by default)

    --tag=TAG
      insert \"_<TAG>\" after YYYYMMDD_HHMMSS when renaming
        -TAG can contain only lowercase letters, numbers, and underscores
        -TAG is ignored if filename is already named:
          TAG.ext
          or YYYYMMDD_HHMMSS_TAG.ext
          or YYYYMMDD_HHMMSS_TAG_INDEX.ext
      e.g.:
        > touch 20150601_001.png --date=2015-06-01T19:43:58
        > $EXEC --mtime --tag=screenshot 20150601_001.png
          mv --no-clobber 20150601_001.png 20150601_194358_screenshot_001.png
        > $EXEC --mtime --tag=screenshot 20150601_194358_screenshot_001.png
          skipping rename 20150601_194358_screenshot_001.png

    -n | -s | --no-act | --simulate
      print the commands, but dont actually run 'touch' or 'mv'
      commands are prefixed by '#' to make it clear they werent run

    --shift-hours=HOURS
      same as: --shift-seconds=\$((HOURS * 60 * 60))
        e.g.: --shift-hours=-4  => subtract 4*60*60 seconds
      NOTE: only the last --shift-seconds or --shift-hours has an effect

    --shift-seconds=SECONDS
      add SECONDS seconds to the timestamp, regardless of method chosen
        SECONDS must be an integer (positive, negative, or zero)
        e.g.: --shift-seconds=3600  adds 3600 seconds
      NOTE: only the last --shift-seconds or --shift-hours has an effect
      NOTE: should be used with --exif-only or --mtime-only or --filename-only
            otherwise, mismatch between exif/mtime and filename should occur

    --dur | --subtract-duration
      for each FILE:
        -determine if file is a video by file extension:
          @EXTS_VIDEOS
        -if file is a video:
          -calculate the duration VIDEO_DUR of file in seconds
          -subtract VIDEO_DUR from EXIF_EPOCH and MTIME_EPOCH
          -if --file-dur is given, subtract VIDEO_DUR from FILENAME_EPOCH
      NOTE: this is the default, can be combined with --shift-seconds
    --no-dur | --no-subtract-duration
      -do not calculate duration VIDEO_DUR
      -do not subtract VIDEO_DUR from EXIF_EPOCH or MTIME_EPOCH (or FILENAME_EPOCH)

    --file-dur | --subtract-duration-filename
      -also subtract video duration from FILENAME_EPOCH (and EXIF_EPOCH and MTIME_EPOCH)
      implies: --dur
";

sub main(@){
  my $action = $ACTION_RENAME;
  my $opts = {
    simulate                      => 0,
    parseExif                     => 1,
    parseMtime                    => 1,
    parseFilename                 => 1,
    shiftSeconds                  => 0,
    subtractDuration              => 1,
    allowSubtractDurationFilename => 0,
    quiet                         => 0,
    checkExt                      => 1,
    tag                           => undef,
  };
  my @files;
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(--rename)$/){
      $action = $ACTION_RENAME;
    }elsif($arg =~ /^(--touch)$/){
      $action = $ACTION_TOUCH;
    }elsif($arg =~ /^(--print)$/){
      $action = $ACTION_PRINT;
    }elsif($arg =~ /^(--exif|--exif-only)$/){
      $$opts{parseExif} = 1;
      $$opts{parseMtime} = 0;
      $$opts{parseFilename} = 0;
    }elsif($arg =~ /^(--mtime|--mtime-only)$/){
      $$opts{parseExif} = 0;
      $$opts{parseMtime} = 1;
      $$opts{parseFilename} = 0;
    }elsif($arg =~ /^(--filename|--filename-only)$/){
      $$opts{parseExif} = 0;
      $$opts{parseMtime} = 0;
      $$opts{parseFilename} = 1;
    }elsif($arg =~ /^(--no-exif|--ignore-exif)$/){
      $$opts{parseExif} = 0;
    }elsif($arg =~ /^(--use-exif)$/){
      $$opts{parseExif} = 1;
    }elsif($arg =~ /^(--no-mtime|--ignore-mtime)$/){
      $$opts{parseMtime} = 0;
    }elsif($arg =~ /^(--use-mtime)$/){
      $$opts{parseMtime} = 1;
    }elsif($arg =~ /^(--no-filename|--ignore-filename)$/){
      $$opts{parseFilename} = 0;
    }elsif($arg =~ /^(--use-filename)$/){
      $$opts{parseFilename} = 1;
    }elsif($arg =~ /^(--quiet)$/){
      $$opts{quiet} = 1;
    }elsif($arg =~ /^(--check-ext)$/){
      $$opts{checkExt} = 1;
    }elsif($arg =~ /^(-a|--no-check-ext|--allow-ext)$/){
      $$opts{checkExt} = 0;
    }elsif($arg =~ /^--tag=(.+)$/){
      my $tag = $1;
      die "$USAGE\nERROR: invalid tag $tag\n" if $tag !~ /^[a-z0-9_]+$/;
      $$opts{tag} = $tag;
    }elsif($arg =~ /^(-n|-s|--no-act|--simulate)$/){
      $$opts{simulate} = 1;
    }elsif($arg =~ /^--shift-hours=(-?\d+)$/){
      $$opts{shiftSeconds} = $1 * 60 * 60;
    }elsif($arg =~ /^--shift-seconds=(-?\d+)$/){
      $$opts{shiftSeconds} = $1;
    }elsif($arg =~ /^(--dur|--subtract-duration)$/){
      $$opts{subtractDuration} = 1;
    }elsif($arg =~ /^(--no-dur|--no-subtract-duration)$/){
      $$opts{subtractDuration} = 0;
      $$opts{allowSubtractDurationFilename} = 0;
    }elsif($arg =~ /^(--file-dur|--subtract-duration-filename)$/){
      $$opts{subtractDuration} = 1;
      $$opts{allowSubtractDurationFilename} = 1;
    }elsif(-f $arg){
      push @files, $arg;
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }
  die "$USAGE\nERROR: no files given\n" if @files == 0;
  my @errors;
  for my $file(@files){
    if(-f $file){
      my $isOk = handleFile $opts, $action, $file;
      push @errors, $file if not $isOk;
    }
  }
  if(@errors > 0){
    my $errorsFmt = join "", map {" $_\n"} @errors;
    die "\n\nERROR HANDLING FILES:\n$errorsFmt";
  }
}

sub handleFile($$$){
  my ($opts, $action, $file) = @_;

  my ($dir, $fileName, $ext);
  $fileName = $file;

  if($fileName =~ /^(.*\/)([^\/]+)$/){
    ($dir, $fileName) = ($1, $2);
  }else{
    $dir = "";
  }
  if($fileName =~ /^(.*)(\.\w+)$/){
    ($fileName, $ext) = ($1, $2);
  }else{
    $ext = "";
  }

  if($fileName =~ /\//){
    die "ERROR: could not parse directory of file: $file\n";
  }
  if($$opts{checkExt} and $ext !~ /^\.($REGEX_EXTS_ALL)$/i){
    die "ERROR: invalid ext for $file (use -a to allow any): @EXTS_ALL\n";
  }

  my ($namePrefix, $nameSuffix);

  #extract prefix+suffix from file
  if($fileName =~ /^($PREFIX_REGEX)(.*)$/){
    $namePrefix = $1;
    $nameSuffix = $2;
  }else{
    $namePrefix = "";
    $nameSuffix = $fileName;
  }

  my ($exifEpoch, $exifMillis);
  if($$opts{parseExif}){
    ($exifEpoch, $exifMillis) = exifEpoch $file;
  }else{
    ($exifEpoch, $exifMillis) = (undef, undef);
  }

  my ($mtimeEpoch, $mtimeMillis);
  if($$opts{parseMtime}){
    ($mtimeEpoch, $mtimeMillis) = mtimeEpoch $file;
  }

  my ($fileEpoch, $fileMillis);
  if($$opts{parseFilename} and $nameSuffix =~ /^\d{8}_\d{6}\d{3}0*(?:_|\.|$)/){
    #if filename has millis attached to HHMMSS, assume UTC
    ($fileEpoch, $fileMillis) = filenameEpoch($nameSuffix, $FILE_TZ_MODE_UTC);
  }elsif($$opts{parseFilename} and $nameSuffix =~ /^\d{8}_\d{6}(?:_|\.|$)/){
    ($fileEpoch, $fileMillis) = filenameEpoch($nameSuffix, $FILE_TZ_MODE_LOCAL);
  }else{
    ($fileEpoch, $fileMillis) = (undef, undef);
  }

  my $duration;
  if($$opts{subtractDuration} and $ext =~ /^\.($REGEX_EXTS_VIDEOS)$/i){
    $duration = getDuration($file);
    if(not defined $duration){
      print STDERR "WARNING: could not calculate duration for $file\n";
    }
  }else{
    $duration = undef;
  }

  if(defined $duration){
    $exifEpoch -= int($duration + 0.5) if defined $exifEpoch;
    $mtimeEpoch -= int($duration + 0.5) if defined $mtimeEpoch;

    #filename is written when video starts, so dont subtract duration by default
    if($$opts{allowSubtractDurationFilename}){
      $fileEpoch -= int($duration + 0.5) if defined $fileEpoch;
    }
  }

  my ($targetEpoch, $targetMillis);
  my $omitMillis = 0;
  if(defined $fileEpoch){
    #ensure file matches either exif or mtime if present
    if(defined $exifEpoch){
      #if file and epoch are both parsed:
      #  if file and epoch are within <FILENAME_MATCH_S>s, use filename
      #  otherwise, fail
      my $delta = $fileEpoch - $exifEpoch;
      $delta = 0 - $delta if $delta < 0;
      if($delta > $FILENAME_MATCH_S){
        print STDERR "ERROR: filename more than ${FILENAME_MATCH_S}s apart"
          ." from exif ($fileEpoch vs $exifEpoch)\n";
        return 0;
      }

      if(defined $fileMillis and defined $exifMillis){
        if($fileMillis eq $exifMillis){
          #if same SubSecTime is already stored in EXIF, omit from filename
          $omitMillis = 1;
        }else{
          print STDERR "ERROR: mismatched millis file vs exif ($fileMillis vs $exifMillis)\n";
          return 0;
        }
      }
    }elsif(defined $mtimeEpoch){
      #if file and mtime are both parsed:
      #  if file and mtime are within <FILENAME_MATCH_S>s, use filename
      #  otherwise, fail
      my $delta = $fileEpoch - $mtimeEpoch;
      $delta = 0 - $delta if $delta < 0;
      if($delta > $FILENAME_MATCH_S){
        print STDERR "ERROR: filename more than ${FILENAME_MATCH_S}s apart"
          ." from mtime ($fileEpoch vs $mtimeEpoch)\n";
        return 0;
      }
    }

    ($targetEpoch, $targetMillis) = ($fileEpoch, $fileMillis);
  }elsif(defined $exifEpoch){
    #if epoch is set, and file is not, use epoch and ignore mtime
    ($targetEpoch, $targetMillis) = ($exifEpoch, $exifMillis);
  }elsif(defined $mtimeEpoch){
    ($targetEpoch, $targetMillis) = ($mtimeEpoch, $mtimeMillis);
  }else{
    ($targetEpoch, $targetMillis) = (undef, undef);
    print STDERR "ERROR: could not calculate any epoch for file $file\n";
    return 0;
  }

  $targetEpoch += $$opts{shiftSeconds};

  my $dateFmt = convertEpochToDateFmt $targetEpoch, "%Y%m%d_%H%M%S";

  my ($ymd, $hms);
  if($dateFmt =~ /^(\d\d\d\d\d\d\d\d)_(\d\d\d\d\d\d)$/){
    ($ymd, $hms) = ($1, $2);
  }else{
    die "ERROR: malformed output of `date` \"$dateFmt\"\n";
  }

  #trim date/time or date from suffix
  if($nameSuffix =~ /^(\d\d\d\d\d\d\d\d_\d\d\d\d\d\d)(\d\d\d)?0*((?:_|\.).*)?$/){
    #remove *any* datetime from any file suffix like ########_###### or ########_######_*
    #e.g.: orig file:  20181101_024332.jpg
    #      with:       suffix=20181101_024332, exif_datetime=20181031_224332
    #      would be:   20181031_224332_20181101_024332.jpg
    #      trimmed to: 20181031_224332.jpg

    my ($removedDtm, $nameMillis, $trimmedNameSuffix) = ($1, $2, $3);
    $trimmedNameSuffix = "" if not defined $trimmedNameSuffix;

    if($trimmedNameSuffix =~ /^(\.\w+)+$/){
      #.NIGHT => _NIGHT
      #.PORTRAIT.ORIGINAL => _PORTRAIT_ORIGINAL
      $trimmedNameSuffix =~ s/\./_/g;
    }

    $nameSuffix = $trimmedNameSuffix;
  }elsif($nameSuffix =~ /^${ymd}(_.*)?/){
    #remove *exactly matching* YYYYMMDD from file suffix, where YYYYMMDD is the target date
    #e.g.: orig file:  20180501_001.png
    #      with:       suffix=20180501_001, exif_datetime=20180501_134155
    #      would be:   20180501_134155_20180501_001.jpg
    #      trimmed to: 20180501_134155_001.jpg

    my ($trimmedNameSuffix) = ($1);
    $trimmedNameSuffix = "" if not defined $trimmedNameSuffix;

    $nameSuffix = $trimmedNameSuffix;
  }

  if(defined $targetMillis and not $omitMillis){
    $nameSuffix = sprintf("_%03dms", $targetMillis) . $nameSuffix;
  }

  $namePrefix =~ s/^_+//;
  $namePrefix =~ s/_+$//;
  $nameSuffix =~ s/^_+//;
  $nameSuffix =~ s/_+$//;

  if(defined $$opts{tag} and $nameSuffix !~ /^$$opts{tag}(_.*)?$/){
    #prepend <TAG> to file suffix, unless file suffix is already <TAG> or <TAG>_<SUFFIX>
    if(length $nameSuffix > 0){
      $nameSuffix = "$$opts{tag}_${nameSuffix}";
    }else{
      $nameSuffix = "$$opts{tag}";
    }
  }

  $namePrefix = "${namePrefix}_" if length $namePrefix > 0;
  $nameSuffix = "_${nameSuffix}" if length $nameSuffix > 0;

  my $newFile;
  my $count = 0;
  while(1){
    my $countFmt = $count == 0 ? "" : "_$count";
    $newFile = "${dir}${namePrefix}${dateFmt}${nameSuffix}${countFmt}${ext}";

    if(not -e $newFile or $file eq $newFile){
      #ensure file does not exist, unless its unchanged from original file
      last;
    }else{
      #otherwise, append an incremental index until file does not exist
      $count++;
    }
  }

  if($action eq $ACTION_RENAME){
    if($file eq $newFile){
      print "skipping rename $file\n" unless $$opts{quiet};
      return 1;
    }else{
      my @mvCmd = ("mv", "--no-clobber", $file, $newFile);
      if($$opts{simulate}){
        print "#@mvCmd\n";
      }else{
        run @mvCmd;
        return $? == 0 ? 1 : 0;
      }
    }
  }elsif($action eq $ACTION_TOUCH){
    my ($epochMtime, $millisMtime) = mtimeEpoch $file;
    if($targetEpoch == $epochMtime){
      print "skipping touch $file\n" unless $$opts{quiet};
    }else{
      my @touchCmd = ("touch", $file, "--date", "\@$targetEpoch");
      if($$opts{simulate}){
        print "#@touchCmd\n";
      }else{
        run @touchCmd;
        return $? == 0 ? 1 : 0;
      }
    }
  }elsif($action eq $ACTION_PRINT){
    my ($epochMtime, $millisMtime) = mtimeEpoch $file;
    my $isSameFilename = $file eq $newFile;
    my $isSameMtime = $targetEpoch == $epochMtime;
    printf "%d (%d) %s (%s) %s %s\n",
      $targetEpoch,
      $epochMtime,
      $file,
      $newFile,
      $isSameFilename ? "(same file)" : "(diff file)",
      $isSameMtime ? "(same mtime)" : "(diff mtime)",
      ;
    return 1;
  }else{
    die "unknown action: $action\n";
  }
}

sub exifEpoch($){
  my ($file) = @_;

  my $isJpeg;
  if($file =~ /\.(jpg|jpeg)$/i){
    $isJpeg = 1;
  }

  my $epoch = undef;
  my $millis = undef;

  if($isJpeg){
    #fetch epoch+millis with quick but not reliable `exif`
    ($epoch, $millis) = exifGetDateAsEpochCmdExif($file);
  }

  if(not defined $epoch){
    #fetch epoch+millis with slower `exiftool`
    ($epoch, $millis) = exifGetDateAsEpochCmdExiftool($file);
  }

  if(not defined $epoch){
    die "ERROR: could not get EXIF date/time with exif/exiftool for $file\n";
  }

  return ($epoch, $millis);
}

sub exifGetDateAsEpochCmdExif($){
  my ($file) = @_;

  my $failed = 0;
  my $epoch = undef;
  my $millis = undef;

  my @lines;
  if(isCmdAvail("exif")){
    my @cmd = ("exif", "-m", $file);
    @lines = readProc @cmd;

    if($? != 0){
      print STDERR "WARNING: error running '@cmd'\n";
      $failed = 1;
      @lines = ();
    }
  }else{
    $failed = 1;
  }

  for my $line(@lines){
    if($line =~ /^Date and Time[^\t]*\t(.+)$/){
      my $dt = $1;
      if($dt =~ /^(\d\d\d\d):(\d\d):(\d\d) (\d\d):(\d\d):(\d\d)$/){
        my ($y, $m, $d, $hr, $min, $sec) = ($1, $2, $3, $4, $5, $6);
        my $fieldEpoch = convertDateFmtToEpoch "$y-$m-$d $hr:$min:$sec";
        if($fieldEpoch !~ /^\d+$/){
          print STDERR "WARNING: skipping `exif`, failed to convert date to epoch $file: $fieldEpoch\n";
          $failed = 1;
          last;
        }
        if(defined $epoch and $epoch ne $fieldEpoch){
          print STDERR "WARNING: skipping `exif`, mismatched Date tags for $file: $epoch != $fieldEpoch\n";
          $failed = 1;
          last;
        }
        $epoch = $fieldEpoch;
      }else{
        print STDERR "WARNING: skipping `exif`, malformed Date tag for $file: $line\n";
        $failed = 1;
        last;
      }
    }elsif($line =~ /^Sub-second Time[^\t]*\t(\d+)$/){
      my $fieldMillis = $1;
      if(defined $millis and $millis ne $fieldMillis){
        print STDERR "WARNING: skipped `exif`, mismatched SubSec tags for $file: $millis != $fieldMillis\n";
        $failed = 1;
        last;
      }
      $millis = $fieldMillis;
    }
  }

  if(not $failed and not defined $epoch){
    print STDERR "WARNING: skipping `exif`, no date/time found for $file\n";
    $failed = 1;
  }

  if($failed){
    return (undef, undef);
  }else{
    return ($epoch, $millis);
  }
}

sub exifGetDateAsEpochCmdExiftool($){
  my ($file) = @_;

  my @dateFields = qw(
    CreateDate
    DateTimeOriginal
  );
  my @otherFields = qw(
    SubSecTime
  );
  my @exifFieldArgs = map {"-$_"} (@dateFields, @otherFields);

  my @exifToolCmd = ("exiftool",
    "-ignoreMinorErrors",
    "-api", "QuickTimeUTC", #parse quicktime date/time tags (not JPEG exif) as UTC
    "-S",                   #very short field names
    "-d", "%s",             #format date/times as epoch (implicitly uses date field + OffsetTime)
    @exifFieldArgs,
    $file,
  );
  my $out = readProc @exifToolCmd;
  die "ERROR: command '@exifToolCmd' failed\n" if $? != 0;
  chomp $out;

  my $epoch;
  for my $dateField(@dateFields){
    if($out =~ /^$dateField\s*:\s*(\d+)$/m){
      $epoch = $1;
      last;
    }
  }
  my $millis = $out =~ /^SubSecTime\s*:\s*(\d+)$/m ? $1 : undef;

  if(not defined $epoch){
    die "ERROR: malformed output '@exifToolCmd':\n$out\n";
  }
  return ($epoch, $millis);
}

sub getDuration($){
  my ($file) = @_;
  my $out = readProc "duration", "-s", "-n", $file;
  if($out =~ /^(\d+|\d*\.\d+)$/){
    return $1;
  }else{
    return undef;
  }
}

sub mtimeEpoch($){
  my ($file) = @_;
  my $mtime = (stat $file)[9];
  my $epoch = int($mtime);
  my $millis = int($mtime*1000.0) % 1000;
  return ($epoch, $millis);
}

sub filenameEpoch($$){
  my ($fileNameSuffix, $fileTzMode) = @_;

  my ($y, $m, $d, $hr, $min, $sec, $millis);
  if($fileNameSuffix =~ /^(\d\d\d\d)(\d\d)(\d\d)_(\d\d)(\d\d)(\d\d)(\d\d\d)0*(?:_|\.|$)/){
    ($y, $m, $d, $hr, $min, $sec, $millis) = ($1, $2, $3, $4, $5, $6, $7);
  }elsif($fileNameSuffix =~ /^(\d\d\d\d)(\d\d)(\d\d)_(\d\d)(\d\d)(\d\d)(?:_|\.|$)/){
    ($y, $m, $d, $hr, $min, $sec, $millis) = ($1, $2, $3, $4, $5, $6, undef);
  }else{
    die "ERROR: could not parse YYYYMMDD_HHMMSS[FFF] in file suffix $fileNameSuffix\n";
  }

  my $dateFmt = "$y-$m-$d" . "T" . "$hr:$min:$sec";

  $dateFmt .= "Z" if $fileTzMode eq $FILE_TZ_MODE_UTC;

  my $epoch = convertDateFmtToEpoch $dateFmt;
  if($epoch =~ /^\d+$/){
    return ($epoch, $millis);
  }else{
    die "ERROR: could not read datetime fmt '$dateFmt' using `date`\n";
  }
}

sub isCmdAvail($){
  my ($cmd) = @_;
  if($cmd =~ /["'\\\$\{\}\[\]:; \t\r\n!#%&^*]/){
    die "ERROR: invalid command \"$cmd\"\n";
  }
  my $out = readProc "sh", "-c", "command -v '$cmd'";
  if($? == 0 and $out =~ /^\/.*$cmd$/){
    return 1;
  }else{
    return 0;
  }
}

sub convertDateFmtToEpoch($){
  my ($dateFmt) = @_;
  my $epoch = readProc "date", "--date", $dateFmt, "+%s";
  chomp $epoch;
  return $epoch;
}

sub convertEpochToDateFmt($$){
  my ($epoch, $formatSpec) = @_;
  my $dateFmt = readProc "date", "--date", "\@$epoch", "+$formatSpec";
  chomp $dateFmt;
  return $dateFmt;
}

sub readProc(@){
  my (@cmd) = @_;
  open my $cmdH, "-|", @cmd or die "ERROR: \"@cmd\" failed\n$!\n";
  my @lines = <$cmdH>;
  close $cmdH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;
  }
}

sub run(@){
  print "@_\n";
  system @_;
}

&main(@ARGV);
