#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

my $SESSION_NAME_MAX_LEN = 75; #the real limit of 80 breaks sometimes

my $EXEC = basename $0;

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC [OPTS] CMD [ARG ARG ..]
    run command inside screen
      -get SESSION_NAME
        -if --session=SESSION_NAME is given, use that
        -otherwise, calculate SESSION_NAME as:
          -use \"scmd_CMD_ARG_ARG\"
          -replace all non-word characters with underscores
          -replace any amount of repeating underscores with a single underscore
          -remove leading/trailing underscores
          -trim to $SESSION_NAME_MAX_LEN characters
      -kill session with: screen -S <SESSION_NAME> -X quit
      -start a new session: screen -S <SESSION_NAME> -d -m <CMD> <ARG> <ARG>

  OPTS
    -a | --attach
    -r | --reattach
    --no-detach
      do not detach from the screen session after starting it (omit '-d')

    -s SESSION_NAME | -S SESSION_NAME
    --session=SESSION_NAME
      use <SESSION_NAME> instead of 'scmd_CMD_ARG_ARG'
";

sub main(@){
  my @cmd;
  my $opts = {
    detach      => 1,
    sessionName => undef,
  };
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(-a|--attach|-r|--reattach|--no-detach)$/){
      $$opts{detach} = 0;
    }elsif($arg =~ /^--session=(.+)$/){
      $$opts{sessionName} = $1;
    }elsif($arg =~ /^(-s|-S)$/ and @_ > 0){
      $$opts{sessionName} = shift @_;
    }elsif($arg =~ /^[^-]/){
      #cmd starts with first arg that does not start with hyphen
      @cmd = ($arg, @_);
      @_ = ();
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  die "$USAGE\nERROR: missing CMD\n" if @cmd == 0;

  my $sessionName;
  if(defined $$opts{sessionName}){
    $sessionName = $$opts{sessionName};
  }else{
    $sessionName = join("_", ("scmd", @cmd));
    $sessionName =~ s/\W+/_/g;
    $sessionName =~ s/__+/_/g;
    $sessionName =~ s/^_//;
    $sessionName =~ s/_$//;
    $sessionName = substr($sessionName, 0, $SESSION_NAME_MAX_LEN);
  }

  my @detachArg = $$opts{detach} ? ("-d") : ();

  system "screen -S $sessionName -X quit >/dev/null";
  system "screen", "-S", $sessionName, @detachArg, "-m", @cmd;
}

&main(@ARGV);
