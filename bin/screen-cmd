#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

my $SESSION_NAME_MAX_LEN = 75; #the real limit of 80 breaks sometimes

my $EXEC = basename $0;

my $USAGE = "Usage:
  $EXEC [OPTS] CMD [ARG ARG ..]
    daemonizes a command with screen

    sets up a screen session and runs \"CMD ARG ARG ..\"
      session is named \"screencmd_CMD_ARG_ARG..._ARG\",
      with all non-word characters replaced with hyphens,
      trimmed to $SESSION_NAME_MAX_LEN characters

    kills any screen sessions with that name, starts a new screen session,
      runs the command, and detaches from the screen session

  OPTS
    -a | --attach
    -r | --reattach
    --no-detach
      do not detach from the screen session after starting it (omit '-d')
";

sub main(@){
  my @cmd;
  my $opts = {
    detach => 1,
  };
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-a|--attach|-r|--reattach|--no-detach)$/){
      $$opts{detach} = 0;
    }elsif($arg =~ /^[^-]/){
      #cmd starts with first arg that does not start with hyphen
      @cmd = ($arg, @_);
      @_ = ();
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  die "$USAGE\nERROR: missing CMD\n" if @cmd == 0;

  my $screenSession = join "_", ("screencmd", @cmd);
  $screenSession =~ s/\W/-/g;
  $screenSession = substr $screenSession, 0, $SESSION_NAME_MAX_LEN;

  my @detachArg = $$opts{detach} ? ("-d") : ();

  system "screen -S $screenSession -X quit >/dev/null";
  system "screen", "-S", $screenSession, @detachArg, "-m", @cmd;
}

&main(@ARGV);
