#!/usr/bin/perl
#Copyright 2011,2012 by Elliot Wolk
#This is free software, released under the GPLv3
use strict;
use warnings;
use File::Basename qw(basename);
use IPC::Run qw(run);

my $IS_THREADED = eval 'use threads; use threads::shared; 1';

sub cleanupFailures($$);
sub formatStatus($$);
sub findImages($);
sub statImage($);
sub getInfo($);
sub checkInfo($$);
sub handleImage($$$$$);
sub runJhead($$);
sub getNewPix($);
sub isOrientMatch($$$$);
sub getResizePercent($$$$);
sub runMogrify($@);
sub writeFile($$);
sub runCmd(@);
sub ipcRunCmd(@);

my $EXEC = basename $0;

my $EXEC_MOGRIFY = 'mogrify';
my $EXEC_IDENTIFY = 'identify';
my $EXEC_JHEAD = 'jhead';

my @EXTS = qw(jpg jpeg png);

my $DEFAULT_MAX_THREADS = 4;

my $DEFAULT_TARGET_X = 1920;
my $DEFAULT_TARGET_Y = 1080;

my $JHEAD_MODE_AUTOROT = "-autorot";
my $JHEAD_MODE_NOROT = "-norot";

my $DEFAULT_PAD_COLOR = "black";
my $DEFAULT_PAD_GRAVITY = "center";

my $SHARPEN_SIZE_PCT_THRESHOLD = 90;
my $UNSHARP_ARG = "0x0.5";

my $OK_GRAVITY = join "|", split /\n+/, `$EXEC_MOGRIFY -list gravity 2>/dev/null`;

my $USAGE = "Usage:
  $EXEC [<OPTS>] <SRC_DIR> <DEST_DIR>
    Create a recursive copy of images from <SRC_DIR> to <DEST_DIR>,
      resized to fit <TARGET_X>x<TARGET_Y>, preserving original aspect ratios.

    The original filesize and modified timestamp are recorded for each file
      under a dir called pixmirror-info/, with the same relative path
      as the original, appended with \".info\".
    If copies already exist on the target, they are not replaced unless the
      mtime or filesize of the original has changed, even if new arguments
      are given.

    If the image is being downscaled to less than
      $SHARPEN_SIZE_PCT_THRESHOLD\%, pixmirror runs '-unsharp $UNSHARP_ARG'
      after resizing to slightly sharpen the image.

    Mirrored images are auto-rotated from EXIF metadata using '$EXEC_JHEAD'

  <OPTS>
    --size=<TARGET_X>x<TARGET_Y>   {default is ${DEFAULT_TARGET_X}x${DEFAULT_TARGET_Y}}
      target width and height in pixels {or height and width if src y>x}

    --orient  --no-orient          {default is --no-orient}
      optionally swap <TARGET_X> and <TARGET_Y> to match orientation of image
      NOTE: does not rotate the image, simply adjusts the target size
      for each image:
        if <TARGET_X> is larger than <TARGET_Y> (landscape),
          but the source image has Y >= X (portrait),
          or vice-versa,
        then: swap <TARGET_X> and <TARGET_Y> for that image
      e.g.:
        rm -rf src/ destOrient/ destNoOrient/
        mkdir src/
        convert -size 2160x3840 xc:red src/empty-portrait.jpg
        $EXEC --orient    --size=1920x1080 src/ destOrient/
        $EXEC --no-orient --size=1920x1080 src/ destNoOrient/
        #pix dest*/empty-portrait.jpg
        #1080x1920 destOrient/empty-portrait.jpg
        #608x1080 destNoOrient/empty-portrait.jpg

    --rotate  --no-rotate          {default is --no-rotate}
      Implies --orient. Instead of just scaling like --orient,
        actually rotate 90 degress clockwise if the orientations do not match.
      This is done after '$EXEC_JHEAD' auto-rotation

    --pad  --no-pad                {default is --no-pad}
      Produce images that are exactly <TARGET_X>x<TARGET_Y> by padding
        with a solid black border on top/bottom or left/right.

    --pad-color=<COLOR>            {default is $DEFAULT_PAD_COLOR}
      when --pad is given, set the background to <COLOR>

    --pad-gravity=<GRAVITY>        {default is $DEFAULT_PAD_GRAVITY}
      when padding, use gravity=<GRAVITY>
      <GRAVITY> is one of {$OK_GRAVITY}
      e.g.: $EXEC --size=5000x50 --pad --pad-gravity=South
               append 4950 rows of black pixels to the top of a 50x50 image

    --no-threads  --nothreads      {default is --threads=$DEFAULT_MAX_THREADS}
      synonym for --threads=1

    --threads=THREAD_COUNT         {default is $DEFAULT_MAX_THREADS}
      use up to THREAD_COUNT threads. if THREAD_COUNT is 1, do not use threads.
      if perl was not built with threads, this is ignored.
        (threads " . ($IS_THREADED ? "ARE" : "are NOT") . " enabled)
      default is $DEFAULT_MAX_THREADS
";

sub main(@){
  my $opts = {
    targetX     => $DEFAULT_TARGET_X,
    targetY     => $DEFAULT_TARGET_Y,

    orientSwap  => 0,
    rotate      => 0,

    pad         => 0,
    padColor    => $DEFAULT_PAD_COLOR,
    padGravity  => $DEFAULT_PAD_GRAVITY,
    threadCount => $DEFAULT_MAX_THREADS,
  };

  while(@_ > 0 and $_[0] =~ /^-/){
    my $arg = shift;
    if($arg =~ /^--size=(\d+)x(\d+)$/){
      $$opts{targetX} = $1+0;
      $$opts{targetY} = $2+0;
    }elsif($arg =~ /^--orient$/){
      $$opts{orientSwap} = 1;
    }elsif($arg =~ /^--no-orient$/){
      $$opts{orientSwap} = 0;
    }elsif($arg =~ /^--rotate$/){
      $$opts{rotate} = 1;
    }elsif($arg =~ /^--no-rotate$/){
      $$opts{rotate} = 0;
    }elsif($arg =~ /^--pad$/){
      $$opts{pad} = 1;
    }elsif($arg =~ /^--no-pad$/){
      $$opts{pad} = 0;
    }elsif($arg =~ /^--pad-color=(\w+)$/){
      $$opts{padColor} = $1;
    }elsif($arg =~ /^--pad-gravity=($OK_GRAVITY)$/i){
      $$opts{padGravity} = $1;
    }elsif($arg =~ /^(--nothreads|--no-threads)$/){
      $$opts{threadCount} = 1;
    }elsif($arg =~ /^--threads=(\d+)$/){
      $$opts{threadCount} = $1;
      die "invalid THREAD_COUNT=$$opts{threadCount}\n" if $$opts{threadCount} <= 0;
    }else{
      die $USAGE;
    }
  }

  my $srcDir = shift;
  my $destDir = shift;

  die $USAGE if not defined $srcDir or not defined $destDir or @_ > 0;

  runCmd "mkdir '$destDir' 2>/dev/null" if not -e $destDir;
  die "src '$srcDir' is not a directory" if not -d $srcDir;
  die "dest '$destDir' is not a directory" if not -d $destDir;

  system "which $EXEC_MOGRIFY > /dev/null";
  die "Could not exec $EXEC_MOGRIFY\n" if $? != 0;
  system "which $EXEC_IDENTIFY > /dev/null";
  die "Could not exec $EXEC_IDENTIFY\n" if $? != 0;

  my @srcImgs = findImages $srcDir;
  my $total = @srcImgs;

  print "running stat on $total images:\n";
  my %srcInfos;
  for my $img(@srcImgs){
    $srcInfos{$img} = statImage "$srcDir/$img";
  }

  print "comparing existing pixmirror info to src info:\n";
  my @destImgs = findImages $destDir;
  my %okImgs;
  for my $img(@destImgs){
    if(not checkInfo($srcInfos{$img}, "$destDir/pixmirror-info/$img.info")){
      print "removing $destDir/$img and $destDir/pixmirror-info/$img.info\n";
      runCmd "rm", "$destDir/$img";
      runCmd "rm", "$destDir/pixmirror-info/$img.info";
    }else{
      $okImgs{$img} = 1;
    }
  }

  @srcImgs = grep {not defined $okImgs{$_}} @srcImgs;
  my $toConvert = @srcImgs;
  my $skipped = $total - $toConvert;

  print "\nconverting $toConvert images {skipped $skipped}\n";

  my $statusCheckpointSize = 10;

  if($IS_THREADED and $$opts{threadCount} > 1){
    my %status;
    my $count = 0;
    my $abort = 0;
    share(\%status);
    share(\$count);
    share(\$abort);

    my @threadChunks;
    my $threadChunk = undef;
    my $size = @srcImgs/$$opts{threadCount};
    for my $img(@srcImgs){
      if(not defined $threadChunk){
        $threadChunk = [];
        push @threadChunks, $threadChunk;
      }
      push @$threadChunk, $img;
      if(@threadChunks < $$opts{threadCount} and @$threadChunk >= $size){
        $threadChunk = undef;
      }
    }

    $SIG{'INT'} = sub {
      print STDERR "\n\ncaught SIGINT, exiting each thread after current file\n\n";
      $abort = 1;
    };

    my @threads;
    for my $chunk(@threadChunks){
      my $t = threads->create(sub {
        my $threadNum = threads->tid();
        print STDERR "     thread#$threadNum: STARTED\n";
        $SIG{'INT'} = sub {
          print STDERR "\n\ncaught SIGINT, exiting each thread after current file\n\n";
          $abort = 1;
        };

        for my $img(@$chunk){
          $status{$img} = 0;
          handleImage $opts, $img, $srcDir, $destDir, $srcInfos{$img};
          $status{$img} = 1;

          if($abort){
            print STDERR "     thread#$threadNum: ERROR (aborting)\n";
            return;
          }

          {
            lock($count);
            $count++;
            if($count % $statusCheckpointSize == 0){
              print STDERR "     ALL: $count / $toConvert\n";
            }
          }
        }
        print STDERR "     thread#$threadNum: FINISHED\n";
      });
      push @threads, $t;
    }

    for my $t(@threads){
      $t->join();
    }
    print STDERR "\n\nall threads joined\n";

    cleanupFailures $destDir, \%status;

    print STDERR formatStatus(\%status, \@srcImgs);
  }else{
    my $count = 0;
    for my $img(@srcImgs){
      handleImage $opts, $img, $srcDir, $destDir, $srcInfos{$img};
      $count++;
      if($count % $statusCheckpointSize == 0){
        print STDERR "     $count / $toConvert\n";
      }
    }
  }

  print "\n\nremoving empty dirs\n";
  runCmd "cd \"$destDir\" && find -mindepth 1 -depth -type d -empty -delete";
}

sub cleanupFailures($$){
  my ($destDir, $status) = @_;

  for my $img(keys %$status){
    if($$status{$img} == 0){
      print STDERR "\nFAILED: $img\n";
      my @files = ("$destDir/$img", "$destDir/pixmirror-info/$img.info");
      @files = grep {-f $_} @files;
      if(@files == 0){
        print STDERR "  no temp files to cleanup\n";
      }else{
        print STDERR "  cleaning up tmp files: @files\n";
        runCmd "rm", "-f", @files;
      }
    }
  }
}

sub formatStatus($$){
  my ($status, $srcImgs) = @_;
  my $totalCnt = @$srcImgs;
  my $successCnt = grep {$$status{$_} == 1} keys %$status;
  my $failCnt = grep {$$status{$_} == 0} keys %$status;
  my $skipCnt = $totalCnt - $successCnt - $failCnt;
  if($totalCnt == $successCnt and $failCnt == 0 and $skipCnt == 0){
    return "\nSUCCESS: $totalCnt images handled\n";
  }else{
    return "\nFAILURE: $successCnt/$totalCnt images handled"
      . " ($skipCnt skipped, $failCnt failed)\n";
  }
}

sub findImages($){
  my $dir = shift;
  my @findArgs = join " -or ", map {"-iname '*.$_'"} @EXTS;

  my @imgs = `cd $dir; find @findArgs`;
  map {chomp} @imgs;
  return sort @imgs;
}

sub statImage($){
  my $img = shift;
  my @stat = stat $img;
  die "failed stat on '$img'\n" if @stat != 13;

  my ($dev,$ino,$mode,$nlink,$uid,$gid,$rdev,$size,
    $atime,$mtime,$ctime,$blksize,$blocks) = @stat;
  return "$size|$mtime\n";
}

sub checkInfo($$){
  my ($srcInfo, $destInfoFile) = @_;
  if(not defined $srcInfo or not -e $destInfoFile){
    return 0;
  }

  open FH, "< $destInfoFile\n";
  my $destInfo = join '', <FH>;
  close FH;
  return $destInfo eq $srcInfo;
}

sub getInfo($){
  my $file = shift;
  $file =~ s/'/'\\''/g;
  my $info = `identify -verbose '$file'`;
  my ($format, $x, $y);
  if($info =~ /^\s*Format: (\w+)/m){
    $format = $1;
  }
  if($info =~ /^\s*Geometry: (\d+)x(\d+)/m){
    ($x, $y) = ($1, $2);
  }
  if(not defined $format or not defined $x or not defined $y){
    die "Error getting geometry/format using imagemagick: identify $file\n";
  }
  return {format=>$format, x=>$x, y=>$y};
}

sub handleImage($$$$$){
  my ($opts, $img, $srcDir, $destDir, $statInfo) = @_;

  my $parent = "$destDir/$img";
  $parent =~ s/\/[^\/]*$/\//;
  runCmd "mkdir", "-p", $parent;

  runCmd "cp", "-L", "--reflink=auto", "$srcDir/$img", "$destDir/$img";

  my $info = getInfo "$destDir/$img";
  my $isJpeg = $$info{format} =~ /JPEG/i;
  my $jpgAutoRot = undef;
  if($isJpeg){
    $jpgAutoRot = runJhead "$destDir/$img", $JHEAD_MODE_AUTOROT;
    $info = getInfo "$destDir/$img";
  }

  my ($oldX, $oldY) = ($$info{x}, $$info{y});
  my ($newX, $newY) = ($$opts{targetX}, $$opts{targetY});

  my @args;
  if($$opts{rotate} and not isOrientMatch $oldX, $oldY, $newX, $newY){
    @args = (@args, "-rotate", 90);
    ($oldX, $oldY) = ($oldY, $oldX);
  }elsif($$opts{orientSwap} and not isOrientMatch $oldX, $oldY, $newX, $newY){
    ($newX, $newY) = ($newY, $newX);
  }

  my $percent = getResizePercent $newX, $newY, $oldX, $oldY;
  @args = (@args, "-resize", "$percent%");

  if($percent < $SHARPEN_SIZE_PCT_THRESHOLD){
    @args = (@args, "-unsharp", $UNSHARP_ARG);
  }

  if($$opts{pad}){
    @args = (@args,
      "-gravity", $$opts{padGravity},
      "-background", $$opts{padColor},
      "-extent", "${newX}x${newY}",
    );
  }

  runMogrify "$destDir/$img", @args;

  my $jpgNoRot = undef;
  if($isJpeg){
    $jpgNoRot = runJhead "$destDir/$img", $JHEAD_MODE_NOROT;
  }

  #ensure parent dir
  my $infoDir = "$destDir/pixmirror-info/$img";
  $infoDir =~ s/[^\/]*$//;
  runCmd "mkdir", "-p", $infoDir;

  writeFile "$destDir/pixmirror-info/$img.info", $statInfo;

  runCmd "touch", "$destDir/$img", "--reference=$srcDir/$img";
  runCmd "touch", "$destDir/pixmirror-info/$img.info", "--reference=$srcDir/$img";

  my $jheadFmt = "";
  if($isJpeg){
    $jheadFmt .= "?mod"    if $$jpgAutoRot{isModified}      or $$jpgNoRot{isModified};
    $jheadFmt .= "?orient" if $$jpgAutoRot{isErrExifOrient} or $$jpgNoRot{isErrExifOrient};
    $jheadFmt .= "?subdir" if $$jpgAutoRot{isErrExifSubdir} or $$jpgNoRot{isErrExifSubdir};
  }

  my $fmt = sprintf "ok|%-20s| %s\n", $jheadFmt, $img;
  print $fmt;
}

sub runJhead($$){
  my ($file, $jheadMode) = @_;
  my $res = ipcRunCmd $EXEC_JHEAD, $jheadMode, $file;

  my $isModified = 0;
  my $isErrExifOrient = 0;
  my $isErrExifSubdir = 0;

  for my $line(split /\n/, $$res{out}){
    next if $line =~ /^\s*$/;
    if($line =~ /^Modified: \Q$file\E$/){
      $isModified = 1;
    }else{
      print "$line\n";
    }
  }
  for my $line(split /\n/, $$res{err}){
    next if $line =~ /^\s*$/;
    if($line =~ /^Nonfatal Error : '\Q$file\E' Unknown orientation tag$/){
      $isErrExifOrient = 1;
    }elsif($line =~ /^Nonfatal Error : '\Q$file\E' Illegal subdirectory link in Exif header$/){
      $isErrExifSubdir = 1;
    }else{
      print STDERR "$line\n";
    }
  }

  return {
    isModified        => $isModified,
    isErrExifOrient => $isErrExifOrient,
    isErrExifSubdir => $isErrExifSubdir,
  }
}

sub isOrientMatch($$$$){
  my ($x1, $y1, $x2, $y2) = @_;
  my $orient1 = $x1 > $y1 ? "landscape" : "portrait";
  my $orient2 = $x2 > $y2 ? "landscape" : "portrait";
  return $orient1 eq $orient2;
}

sub getResizePercent($$$$){
  my ($newX, $newY, $oldX, $oldY) = @_;
  my $ratio;

  my $ratio1 = $newX / $oldX;
  my $ratio2 = $newY / $oldY;
  $ratio = $ratio1 < $ratio2 ? $ratio1 : $ratio2;

  my $percent = sprintf '%.5f', $ratio*100;

  return $percent;
}

sub runMogrify($@){
  my ($file, @args) = @_;

  runCmd $EXEC_MOGRIFY, @args, $file;
  die "failed to run mogrify on $file {@args}\n" if $? != 0;
}

sub writeFile($$){
  my ($file, $contents) = @_;
  open my $fh, "> $file" or die "ERROR: could not write $file\n$!\n";
  print $fh $contents;
  close $fh;
}

sub runCmd(@){
  my (@cmd) = @_;
  system @cmd;
}

sub ipcRunCmd(@){
  my @cmd = @_;
  my ($out, $err);
  my $success = run [@cmd], '>', \$out, '2>', \$err;
  return {out=>$out, err=>$err, success=>$success};
}

&main(@ARGV);
