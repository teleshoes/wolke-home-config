use strict;
use warnings;
use File::Basename qw(basename dirname);
use IPC::Run qw(run);
use Time::HiRes qw(time);

my $IS_THREADED = eval 'use threads; use threads::shared; use Thread::Queue; 1';
eval 'require "syscall.ph"';

sub syncPixDirs($$$);
sub getSrcImgFile($$);
sub getDestImgFile($$$);
sub getDestInfoFile($$);
sub cleanupFailures($$$);
sub formatOverallStatus($$$);
sub findRelFiles($@);
sub findImages($);
sub readMirrorDirInfos($);
sub statNano($);
sub touchNano($$$$$);
sub syscallResolveNum($$);
sub touchByRef($$$);
sub runStat($);
sub readInfoFile($);
sub writeInfoFile($$$);
sub getIdentifyImgInfo($);
sub checkInfo($$);
sub handleImage($$$$$);
sub getTmpFile($$$);
sub getNewPix($);
sub isOrientMatch($$$$);
sub getResizePercent($$$$);
sub runConvert($$$@);
sub readFile($);
sub writeFile($$$);
sub readProc(@);
sub runCmd($@);
sub ipcRunCmd($@);
sub nowMillis();

my $EXEC = basename $0;

my $EXEC_CONVERT = 'convert';
my $EXEC_IDENTIFY = 'identify';
my $EXEC_EXIFTRAN = 'exiftran';

my @IMG_EXTS = qw(jpg jpeg png bmp heic svg);
my $REGEX_IMG_EXTS = join "|", @IMG_EXTS;

my $DEFAULT_MAX_THREADS = 4;

my $DEFAULT_TARGET_W = 1920;
my $DEFAULT_TARGET_H = 1080;

my $DEFAULT_PAD_COLOR = "black";
my $DEFAULT_PAD_GRAVITY = "center";

my $SHARPEN_SIZE_PCT_THRESHOLD = 90;
my $UNSHARP_ARG = "0x0.5";

my $OK_GRAVITY = join "|", split /\n+/, `$EXEC_CONVERT -list gravity 2>/dev/null`;

my $SYS_STATX = syscallResolveNum("SYS_statx", {x86_64=>332, aarch64=>291});
my $SYS_UTIMENSAT = syscallResolveNum("SYS_utimensat", {x86_64=>280, aarch64=>88});
my $STATX_ALL = 0x0FFF;
my $AT_FDCWD  = -100;
my $AT_SYMLINK_NOFOLLOW = 0x100;

my $USAGE = "Usage:
  $EXEC [<OPTS>] <SRC_DIR> <DEST_DIR>
    Create a recursive copy of images from <SRC_DIR> to <DEST_DIR>,
      resized to fit <TARGET_W>x<TARGET_H>, preserving original aspect ratios,
      converted to JPEG (or PNG with --png) format.

    The original filesize and modified timestamp are recorded for each file
      under a dir called pixmirror-info/, with the same relative path
      as the original, appended with \".info\".
    If copies already exist on the target, they are not replaced unless the
      mtime or filesize of the original has changed, even if new arguments
      are given.

    If the image is being downscaled to less than
      $SHARPEN_SIZE_PCT_THRESHOLD\%, pixmirror runs '-unsharp $UNSHARP_ARG'
      after resizing to slightly sharpen the image.

    Destination images are auto-rotated from EXIF metadata using '$EXEC_EXIFTRAN'

    If the source image file ends in '.jpg' (case-insensitive),
      and that suffix is not preceded by '.<EXT>' (case-insensitive) for any <EXT>
      then the destination mirrored image file is the same as the source
    If the source image file ends in '.<EXT>' or '.<EXT>.jpg' (case-insensitive),
      then destination mirrored image file is the source with '.jpg' appended
    i.e:
      a.jpg     => a.jpg
      a.JPG     => a.JPG
      a.jpeg    => a.jpeg.jpg
      a.png     => a.png.jpg
      a.jpg.jpg => a.jpg.jpg.jpg
      a.png.jpg => a.png.jpg.jpg
      a.jpg.png => a.jpg.png.jpg

    (the above applies to a.png, a.PNG etc if --png is given)

    <EXT>
      one of: @IMG_EXTS

    <SRC_DIR>
      must be an existing directory on the filesystem
    <DEST_DIR>
      must be a directory that can be created or already exists
      cannot start with '-' and can otherwise be any relative or absolute path
        (use './-dirname' instead of '-dirname' if necessary)

  <OPTS>
    -n | -s | --dry-run | --no-act | --simulate | --read-only
      perform a dry-run of sync without making any changes
      -do NOT write any changes to the filesystem
        -do not auto-rotate images with `$EXEC_EXIFTRAN`
        -do not convert images with `$EXEC_CONVERT`
        -do not write info files
        -do not create any directories
        -do not create or cleanup any temp files
      -DO perform read-only actions
        -print all skipped commands as they would be run
        -read image format, geometry, and EXIF orientation with $EXEC_IDENTIFY
        -calculate target size, respecting --orient and --rotate, and EXIF orientation
          (behave as if EXIF auto rotation occurred)

    --jpg
      output in JPEG format with '.jpg' extension
      (this is the default)

    --png
      output in PNG format with '.png' extension

    --trim-ext
      remove source extension from dest file
      WARNING:
        this *REQUIRES* that filenames be unique after removing extension
        'a.heic', 'a.png' and 'a.jpg' will all be named 'a.jpg', overwriting the dest
      NOTE:
        a.png.png will be renamed to a.png.jpg, not a.png

    --size=<TARGET_W>x<TARGET_H>   {default is ${DEFAULT_TARGET_W}x${DEFAULT_TARGET_H}}
      target width and height in pixels {or height and width if src y>x}

    --orient  --no-orient          {default is --no-orient}
      optionally swap <TARGET_W> and <TARGET_H> to match orientation of image,
        after and in addition to EXIF auto-rotating with $EXEC_EXIFTRAN
      NOTE: does not further rotate the image, only adjusts the <TARGET_W> and <TARGET_H>

      for each image:
        -get the <SRC_W> and <SRC_H>, respecting EXIF orientation (i.e.: swapped if 5,6,7,8)
        -caclulate <SRC_ORIENT>:  'landscape' if SRC_W > SRC_H, 'portrait' otherwise
        -caclulate <TARGET_ORIENT>:  'landscape' if TARGET_W > TARGET_H, 'portrait' otherwise
        -if <SRC_ORIENT> is not the same as <TARGET_ORIENT>
          -swap <TARGET_W> and <TARGET_H> values for this image
      e.g.:
        rm -rf src/ destOrient/ destNoOrient/
        mkdir src/
        convert -size 2160x3840 xc:red src/empty-portrait.jpg
        $EXEC --orient    --size=1920x1080 src/ destOrient/
        $EXEC --no-orient --size=1920x1080 src/ destNoOrient/
        #pix dest*/empty-portrait.jpg
        #608x1080 destNoOrient/empty-portrait.jpg
        #1080x1920 destOrient/empty-portrait.jpg

    --rotate  --no-rotate          {default is --no-rotate}
      rotate destination images 90 degrees if necessary,
        in order to match the orientation of <TARGET_W>x<TARGET_H>,
        after and in addition to EXIF auto-rotating with $EXEC_EXIFTRAN
      NOTE: actually rotates the destination image data, preserving <TARGET_W> and <TARGET_H>

      for each image:
        -get the <SRC_W> and <SRC_H>, respecting EXIF orientation (i.e.: swapped if 5,6,7,8)
        -caclulate <SRC_ORIENT>:  'landscape' if SRC_W > SRC_H, 'portrait' otherwise
        -caclulate <TARGET_ORIENT>:  'landscape' if TARGET_W > TARGET_H, 'portrait' otherwise
        -if <SRC_ORIENT> is not the same as <TARGET_ORIENT>
          -swap <SRC_W> and <SRC_H> for calculation against <TARGET_W> and <TARGET_H>
          -rotate the image 90 degrees clockwise while
      e.g.:
        rm -rf src/ destOrient/ destNoOrient/
        mkdir src/
        convert -size 2160x3840 xc:red src/empty-portrait.jpg
        $EXEC --rotate    --size=1920x1080 src/ destRotate/
        $EXEC --no-rotate --size=1920x1080 src/ destNoRotate/
        #pix dest*/empty-portrait.jpg
        #608x1080 destNoRotate/empty-portrait.jpg
        #1920x1080 destRotate/empty-portrait.jpg

    --pad  --no-pad                {default is --no-pad}
      Produce images that are exactly <TARGET_W>x<TARGET_H> by padding
        with a solid black border on top/bottom or left/right.

    --pad-color=<COLOR>            {default is $DEFAULT_PAD_COLOR}
      when --pad is given, set the background to <COLOR>

    --pad-gravity=<GRAVITY>        {default is $DEFAULT_PAD_GRAVITY}
      when padding, use gravity=<GRAVITY>
      <GRAVITY> is one of {$OK_GRAVITY}
      e.g.: $EXEC --size=5000x50 --pad --pad-gravity=South
               append 4950 rows of black pixels to the top of a 50x50 image

    --no-threads  --nothreads      {default is --threads=$DEFAULT_MAX_THREADS}
      synonym for --threads=1

    --threads=THREAD_COUNT         {default is $DEFAULT_MAX_THREADS}
      use up to THREAD_COUNT threads. if THREAD_COUNT is 1, do not use threads.
      if perl was not built with threads, this is ignored.
        (threads " . ($IS_THREADED ? "ARE" : "are NOT") . " enabled)
      default is $DEFAULT_MAX_THREADS
";

sub main(@){
  my $srcDir = undef;
  my $destDir = undef;
  my $opts = {
    simulate    => 0,

    targetExt   => "jpg",
    trimExt     => 0,

    targetW     => $DEFAULT_TARGET_W,
    targetH     => $DEFAULT_TARGET_H,

    orientSwap  => 0,
    rotate      => 0,

    pad         => 0,
    padColor    => $DEFAULT_PAD_COLOR,
    padGravity  => $DEFAULT_PAD_GRAVITY,
    threadCount => $DEFAULT_MAX_THREADS,
  };
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-n|-s|--dry-run|--no-act|--simulate|--read-only)$/){
      $$opts{simulate} = 1;
    }elsif($arg =~ /^--jpg$/){
      $$opts{targetExt} = "jpg";
    }elsif($arg =~ /^--png$/){
      $$opts{targetExt} = "png";
    }elsif($arg =~ /^--trim-ext$/){
      $$opts{trimExt} = 1;
    }elsif($arg =~ /^--size=(\d+)x(\d+)$/){
      $$opts{targetW} = $1+0;
      $$opts{targetH} = $2+0;
    }elsif($arg =~ /^--orient$/){
      $$opts{orientSwap} = 1;
    }elsif($arg =~ /^--no-orient$/){
      $$opts{orientSwap} = 0;
    }elsif($arg =~ /^--rotate$/){
      $$opts{rotate} = 1;
    }elsif($arg =~ /^--no-rotate$/){
      $$opts{rotate} = 0;
    }elsif($arg =~ /^--pad$/){
      $$opts{pad} = 1;
    }elsif($arg =~ /^--no-pad$/){
      $$opts{pad} = 0;
    }elsif($arg =~ /^--pad-color=(\w+)$/){
      $$opts{padColor} = $1;
    }elsif($arg =~ /^--pad-gravity=($OK_GRAVITY)$/i){
      $$opts{padGravity} = $1;
    }elsif($arg =~ /^(--nothreads|--no-threads)$/){
      $$opts{threadCount} = 1;
    }elsif($arg =~ /^--threads=(\d+)$/){
      $$opts{threadCount} = $1;
      die "invalid THREAD_COUNT=$$opts{threadCount}\n" if $$opts{threadCount} <= 0;
    }elsif(-d $arg and not defined $srcDir){
      $srcDir = $arg;
    }elsif($arg !~ /^-/ and not defined $destDir){
      $destDir = $arg;
    }else{
      die $USAGE;
    }
  }

  die $USAGE if not defined $srcDir or not defined $destDir;

  my $success = syncPixDirs($opts, $srcDir, $destDir);
  if($success){
    exit 0;
  }else{
    exit 1;
  }
}

sub syncPixDirs($$$){
  my ($opts, $srcDir, $destDir) = @_;

  $srcDir =~ s/\/+$//;
  $destDir =~ s/\/+$//;

  runCmd $opts, "mkdir '$destDir' 2>/dev/null" if not -e $destDir;
  die "src '$srcDir' is not a directory" if not -d $srcDir;
  if(not $$opts{simulate}){
    die "dest '$destDir' is not a directory" if not -d $destDir;
  }

  system "which $EXEC_CONVERT > /dev/null";
  die "Could not exec $EXEC_CONVERT\n" if $? != 0;
  system "which $EXEC_IDENTIFY > /dev/null";
  die "Could not exec $EXEC_IDENTIFY\n" if $? != 0;

  my @srcImgNames = findImages $srcDir;
  my $countTotal = @srcImgNames;

  print "running stat on src ($countTotal images):\n";
  my $srcStatInfos = {};
  for my $imgName(@srcImgNames){
    my $srcImgFile = getSrcImgFile($srcDir, $imgName);
    $$srcStatInfos{$imgName} = runStat $srcImgFile;
  }

  my %okImgs;

  print "fetching cached stat info on dest:\n";
  my $destStatInfos = readMirrorDirInfos($destDir);
  for my $imgName(sort keys %$destStatInfos){
    my $destImgFile = getDestImgFile($opts, $destDir, $imgName);
    my $destInfoFile = getDestInfoFile($destDir, $imgName);
    if(not checkInfo($$srcStatInfos{$imgName}, $$destStatInfos{$imgName})){
      print "removing $destImgFile and $destInfoFile\n";
      runCmd $opts, "rm", "$destImgFile";
      runCmd $opts, "rm", "$destInfoFile";
    }else{
      $okImgs{$imgName} = 1;
    }
  }

  my @imgNamesToConvert;
  for my $imgName(@srcImgNames){
    if($$srcStatInfos{$imgName}{fsize} == 0){
      print "WARNING: skipping empty file $imgName\n";
    }elsif(not defined $okImgs{$imgName}){
      push @imgNamesToConvert, $imgName;
    }
  }

  my $countToConvert = @imgNamesToConvert;
  my $countSkipped = $countTotal - $countToConvert;

  print "\nconverting $countToConvert images {skipped $countSkipped}\n";

  my $statusCheckpointSize = 10;

  my $statusesByImgName = {};

  if($IS_THREADED and $$opts{threadCount} > 1 and $countToConvert > 0){
    share(\$statusesByImgName);

    my $threadQueue = Thread::Queue->new();

    my @threads;
    for(my $i=0; $i<$$opts{threadCount}; $i++){
      my $t = threads->create(sub {
        my $threadNum = threads->tid();
        print STDERR "     thread#$threadNum: STARTED\n";

        while(my $msg = $threadQueue->dequeue()){
          if(defined $msg and $msg =~ /^imgName=(.+)$/){
            my $imgName = $1;
            $$statusesByImgName{$imgName} = 0;
            my $success = handleImage $opts, $imgName, $srcDir, $destDir, $$srcStatInfos{$imgName};
            if($success){
              $$statusesByImgName{$imgName} = 1;
            }
          }else{
            print STDERR "     thread#$threadNum: ERROR (aborting)\n";
            last;
          }
        }
        print STDERR "     thread#$threadNum: FINISHED\n";
        threads->exit();
      });
      push @threads, $t;
    }

    my $abort = 0;
    $SIG{'INT'} = sub {
      print STDERR "\n\ncaught SIGINT, exiting each thread after current file\n\n";
      $abort = 1;
    };

    #block on enqueue() until a thread takes a job to allow abort
    # limit of 1 is broken and blocks forever for no discernible reason
    $threadQueue->limit = 2;

    for my $imgName(@imgNamesToConvert){
      if($abort){
        last;
      }else{
        $threadQueue->enqueue("imgName=$imgName");

        my $count = 0 + keys %$statusesByImgName;
        if($count % $statusCheckpointSize == 0){
          print STDERR "     ALL: $count / $countToConvert\n";
        }
      }
    }
    $threadQueue->end();

    for my $t(@threads){
      $t->join();
    }

    print STDERR "\n\nall threads joined\n";
  }else{
    my $count = 0;
    for my $imgName(@imgNamesToConvert){
      $$statusesByImgName{$imgName} = 0;
      my $success = handleImage $opts, $imgName, $srcDir, $destDir, $$srcStatInfos{$imgName};
      if($success){
        $$statusesByImgName{$imgName} = 1;
      }
      my $count = 0 + keys %$statusesByImgName;
      if($count % $statusCheckpointSize == 0){
        print STDERR "     $count / $countToConvert\n";
      }
    }
  }

  cleanupFailures $opts, $destDir, $statusesByImgName;
  my $countSuccess = 0 + grep {$$statusesByImgName{$_} == 1} sort keys %$statusesByImgName;
  my $countFailure = 0 + grep {$$statusesByImgName{$_} == 0} sort keys %$statusesByImgName;

  print STDERR formatOverallStatus($countSuccess, $countFailure, $countToConvert);

  print "\n\nremoving empty dirs\n";
  runCmd $opts, "find", "$destDir/", "-mindepth", 1, "-depth", "-type", "d", "-empty", "-delete";

  print "\n\nsyncing dir mtimes\n";
  my @srcSubdirs = readProc "find", "$srcDir/", "-mindepth", 1, "-depth", "-type", "d";
  for my $srcSubdir(@srcSubdirs){
    chomp $srcSubdir;
    my $subdir = undef;
    if($srcSubdir =~ /^$srcDir\/(.+)$/){
      $subdir = $1;
    }else{
      print STDERR "WARNING: malformed dir $srcSubdir\n";
      return 0;
    }
    my $destSubdir = "$destDir/$subdir";
    if(-d $destSubdir){
      touchByRef($opts, $srcSubdir, $destSubdir);
    }
  }

  if($countToConvert == $countSuccess and $countFailure == 0){
    return 1;
  }else{
    return 0;
  }
}

sub getSrcImgFile($$){
  my ($srcDir, $imgName) = @_;
  return "$srcDir/$imgName";
}
sub getDestImgFile($$$){
  my ($opts, $destDir, $imgName) = @_;
  my $targetExt = $$opts{targetExt};

  my ($extPrefix, $extSuffix);
  if($imgName =~ /\.(\w+)\.(\w+)$/){
    ($extPrefix, $extSuffix) = ($1, $2);
  }elsif($imgName =~ /\.(\w+)$/){
    ($extPrefix, $extSuffix) = ("", $1);
  }

  my $skipExtAppend = 0;
  if($extSuffix =~ /^$targetExt$/i){
    if($extPrefix =~ /^($REGEX_IMG_EXTS)$/i){
      #do NOT skip EXT (e.g. jpg) append if file name is '*.png.EXT', '*.EXT.EXT', etc
      #  (otherwise, 'a.png.EXT' and 'a.png' map to the same value: 'a.png.EXT')
      $skipExtAppend = 0;
    }else{
      #skip append if file name is just '*.EXT'
      $skipExtAppend = 1;
    }
  }

  my $destImgFile = "$destDir/$imgName";
  if($$opts{trimExt}){
    $destImgFile =~ s/\.($REGEX_IMG_EXTS)$//i;
    $destImgFile .= ".$targetExt";
  }else{
    $destImgFile .= ".$targetExt" unless $skipExtAppend;
  }

  if($destImgFile !~ /^.+\.$targetExt$/i){
    die "ERROR: invalid destination img file: $destImgFile\n";
  }
  return $destImgFile;
}
sub getDestInfoFile($$){
  my ($destDir, $imgName) = @_;
  return "$destDir/pixmirror-info/$imgName.info";
}

sub cleanupFailures($$$){
  my ($opts, $destDir, $statusesByImgName) = @_;

  for my $imgName(keys %$statusesByImgName){
    if($$statusesByImgName{$imgName} == 0){
      print STDERR "\nFAILED: $imgName\n";
      my @files = (
        getDestImgFile($opts, $destDir, $imgName),
        getDestInfoFile($destDir, $imgName));
      @files = grep {-f $_} @files;
      if(@files == 0){
        print STDERR "  no temp files to cleanup\n";
      }else{
        print STDERR "  cleaning up tmp files: @files\n";
        runCmd $opts, "rm", "-f", @files;
      }
    }
  }
}

sub formatOverallStatus($$$){
  my ($countSuccess, $countFailure, $countToConvert) = @_;
  my $countUnknown = $countToConvert - $countSuccess - $countFailure;
  if($countToConvert == $countSuccess and $countFailure == 0){
    return "\nSUCCESS: $countSuccess images handled\n";
  }else{
    return "\nFAILURE: $countSuccess/$countToConvert images handled"
      . " ($countUnknown unknown, $countFailure failed)\n";
  }
}

sub findRelFiles($@){
  my ($dir, @exts) = @_;

  my @cmd = ("find", "$dir/", "-false");
  @cmd = (@cmd, "-or", "-iname", "*.$_") foreach @exts;

  my @files = readProc @cmd;
  my @okFiles;
  for my $file(@files){
    chomp $file;
    if($file =~ /^$dir\/(.+)$/){
      push @okFiles, $1;
    }else{
      die "ERROR: malformed find output $file\n";
    }
  }
  return sort @okFiles;
}

sub findImages($){
  my ($dir) = @_;
  return findRelFiles($dir, @IMG_EXTS);
}

sub readMirrorDirInfos($){
  my ($mirrorDir) = @_;
  my @infoFiles = findRelFiles("$mirrorDir/pixmirror-info", "info");
  my $mirrorStatInfos = {};
  for my $infoFile(@infoFiles){
    if($infoFile !~ /^(.+)\.info$/){
      die "ERROR: malformed info file $infoFile\n";
    }
    my $imgName = $1;
    $$mirrorStatInfos{$imgName} = readInfoFile "$mirrorDir/pixmirror-info/$infoFile";
  }

  return $mirrorStatInfos;
}

sub statNano($){
  my ($file) = @_;

  my $buf = "\x00" x 256;

  # statx(dirfd, path, flags, mask, buffer)
  my $res = syscall($SYS_STATX, $AT_FDCWD, $file, $AT_SYMLINK_NOFOLLOW, $STATX_ALL, $buf);

  if($res == 0) {
    #struct statx {
    #    __u32 stx_mask;        /* Mask of bits indicating
    #                              filled fields */
    #    __u32 stx_blksize;     /* Block size for filesystem I/O */
    #    __u64 stx_attributes;  /* Extra file attribute indicators */
    #    __u32 stx_nlink;       /* Number of hard links */
    #    __u32 stx_uid;         /* User ID of owner */
    #    __u32 stx_gid;         /* Group ID of owner */
    #    __u16 stx_mode;        /* File type and mode */
    #    __u64 stx_ino;         /* Inode number */
    #    __u64 stx_size;        /* Total size in bytes */
    #    __u64 stx_blocks;      /* Number of 512B blocks allocated */
    #    __u64 stx_attributes_mask;
    #                           /* Mask to show what's supported
    #                              in stx_attributes */
    #
    #    /* The following fields are file timestamps */
    #    struct statx_timestamp stx_atime;  /* Last access */
    #    struct statx_timestamp stx_btime;  /* Creation */
    #    struct statx_timestamp stx_ctime;  /* Last status change */
    #    struct statx_timestamp stx_mtime;  /* Last modification */
    #
    #    /* If this file represents a device, then the next two
    #       fields contain the ID of the device */
    #    __u32 stx_rdev_major;  /* Major ID */
    #    __u32 stx_rdev_minor;  /* Minor ID */
    #
    #    /* The next two fields contain the ID of the device
    #       containing the filesystem where the file resides */
    #    __u32 stx_dev_major;   /* Major ID */
    #    __u32 stx_dev_minor;   /* Minor ID */
    #
    #    __u64 stx_mnt_id;      /* Mount ID */
    #
    #    /* Direct I/O alignment restrictions */
    #    __u32 stx_dio_mem_align;
    #    __u32 stx_dio_offset_align;
    #
    #    __u64 stx_subvol;      /* Subvolume identifier */
    #
    #    /* Direct I/O atomic write limits */
    #    __u32 stx_atomic_write_unit_min;
    #    __u32 stx_atomic_write_unit_max;
    #    __u32 stx_atomic_write_segments_max;
    #
    #    /* File offset alignment for direct I/O reads */
    #    __u32 stx_dio_read_offset_align;
    #
    #    /* Direct I/O atomic write max opt limit */
    #    __u32 stx_atomic_write_unit_max_opt;
    #};
    #
    #struct statx_timestamp {
    #    __s64 tv_sec;    /* Seconds since the Epoch (UNIX time) */
    #    __u32 tv_nsec;   /* Nanoseconds since tv_sec */
    #};

    my ($uid, $gid, $mode, $size,
      $atimeS, $atimeNS, $btimeS, $btimeNS, $ctimeS, $ctimeNS, $mtimeS, $mtimeNS,
    ) = unpack(""
      . "x20"
      . "L"      #4b  @20  uid
      . "L"      #4b  @24  gid
      . "S"      #2b  @28  mode
      . "x10"
      . "Q"      #8b  @40  filesize
      . "x16"
      . "qLx4"   #16b @64  atime
      . "qLx4"   #16b @80  btime
      . "qLx4"   #16b @96  ctime
      . "qLx4"   #16b @112 mtime
      . "",
      $buf,
    );

    return {
      uid     => $uid,
      gid     => $gid,
      mode    => $mode,
      size    => $size,
      atimeS  => $atimeS,
      atimeNS => $atimeNS,
      btimeS  => $btimeS,
      btimeNS => $btimeNS,
      ctimeS  => $ctimeS,
      ctimeNS => $ctimeNS,
      mtimeS  => $mtimeS,
      mtimeNS => $mtimeNS,
    };
  }else{
    print STDERR "WARNING: syscall statx failed on '$file'\n";
    return undef;
  }
}

sub touchNano($$$$$){
  my ($file, $atimeS, $atimeNS, $mtimeS, $mtimeNS) = @_;

  my $timespecArr = pack("q L x4 q L x4", $atimeS, $atimeNS, $mtimeS, $mtimeNS);

  my $res = syscall($SYS_UTIMENSAT, $AT_FDCWD, $file, $timespecArr, $AT_SYMLINK_NOFOLLOW);
  if($res == 0){
    return 1;
  }else{
    print STDERR "WARNING: syscall utimensat failed on '$file'\n";
    return 0;
  }
}

sub syscallResolveNum($$){
  my ($callName, $archList) = @_;
  no strict 'refs';
  my $callNum = undef;
  if(defined &{$callName}){
    $callNum = &{$callName};
  }
  use strict;
  if(defined $callNum){
    return $callNum;
  }else{
    my $arch = `uname -m`;
    chomp $arch;
    if(defined $$archList{$arch}){
      return $$archList{$arch};
    }elsif(defined $$archList{x86_64}){
      return $$archList{x86_64};
    }else{
      die "ERROR: failed to resolve syscall\n";
    }
  }
}

sub touchByRef($$$){
  my ($opts, $refFile, $fileToUpdate) = @_;
  my @stat = stat $refFile;
  if(@stat != 13){
    die "ERROR: could not stat $refFile\n";
  }
  my ($atime, $mtime) = ($stat[8], $stat[9]);
  if(not $$opts{simulate}){
    utime($atime, $mtime, $fileToUpdate);
  }
}

sub runStat($){
  my ($file) = @_;
  my @stat = stat $file;

  return {
    fsize => $stat[7],
    mtime => $stat[9],
  };
}
sub readInfoFile($){
  my ($infoFile) = @_;
  if(not -e $infoFile){
    die "ERROR: missing info file $infoFile\n";
  }

  my $info = readFile $infoFile;
  if($info =~ /^(\d+)\|(\d+)$/){
    return {
      fsize => $1,
      mtime => $2,
    };
  }
}
sub writeInfoFile($$$){
  my ($opts, $infoFile, $statInfo) = @_;
  writeFile $opts, $infoFile, "$$statInfo{fsize}|$$statInfo{mtime}\n";
}

sub checkInfo($$){
  my ($srcStatInfo, $destStatInfo) = @_;
  if(not defined $srcStatInfo or not defined $destStatInfo){
    return 0;
  }
  for my $field(qw(fsize mtime)){
    if(not defined $$srcStatInfo{$field} or not defined $$destStatInfo{$field}){
      return 0;
    }
    if($$srcStatInfo{$field} ne $$destStatInfo{$field}){
      return 0;
    }
  }
  return 1;
}

sub getIdentifyImgInfo($){
  my ($file) = @_;
  my $res = ipcRunCmd {simulate => 0}, $EXEC_IDENTIFY,
    "-format", ":%w:%h:%m:%[exif:orientation]:",
    $file,
  ;
  my $err = $$res{err};
  $err =~ s/^identify: unknown image property "\%\[exif:orientation\]".*\n*//mg;
  print STDERR $err;

  my $out = $$res{out};
  if($out =~ /^:(\d+):(\d+):(\w+):(\d*):$/){
    return {
      width      => $1,
      height     => $2,
      format     => $3,
      exifOrient => $4,
    };
  }else{
    print "\n\n\nERROR: malformed `identify` output for $file:\n$out\n";
    return undef;
  }
}

sub handleImage($$$$$){
  my ($opts, $imgName, $srcDir, $destDir, $statInfo) = @_;

  my $srcImgFile = getSrcImgFile($srcDir, $imgName);
  my $destImgFile = getDestImgFile($opts, $destDir, $imgName);
  my $destInfoFile = getDestInfoFile($destDir, $imgName);

  my $identifyImgInfo = getIdentifyImgInfo $srcImgFile;
  if(not defined $identifyImgInfo){
    return 0;
  }

  my $isJpeg = $$identifyImgInfo{format} =~ /JPEG/i;
  my $exifOrient = $$identifyImgInfo{exifOrient};
  my ($srcW, $srcH) = ($$identifyImgInfo{width}, $$identifyImgInfo{height});

  my $exifRotated = 0;
  my $exifAspectSwapped = 0;

  my $inputImgFile;
  my $tmpFile = undef;
  if($isJpeg and defined $exifOrient and $exifOrient =~ /^(2|3|4|5|6|7|8)$/){
    #img is exif-rotated
    #  use exiftran to auto-rotate img data losslessly and remove exif orient tag
    $tmpFile = getTmpFile("$destDir/pixmirror-tmp", $imgName, ".jpg");
    runCmd $opts, "mkdir", "-p", dirname($tmpFile);
    runCmd $opts, $EXEC_EXIFTRAN, "-a", $srcImgFile, "-o", $tmpFile;
    if($? != 0){
      print "\n\n\n\nERROR: $EXEC_EXIFTRAN failed for $srcImgFile\n\n\n\n";
      return 0;
    }

    $exifRotated = 1;
    if($exifOrient =~ /^(5|6|7|8)$/){
      ($srcW, $srcH) = ($srcH, $srcW);
      $exifAspectSwapped = 1;
    }

    $inputImgFile = $tmpFile;
  }else{
    $inputImgFile = $srcImgFile;
  }

  my ($oldW, $oldH) = ($srcW, $srcH);
  my ($newW, $newH) = ($$opts{targetW}, $$opts{targetH});

  my @args;
  if($$opts{rotate} and not isOrientMatch $oldW, $oldH, $newW, $newH){
    @args = (@args, "-rotate", 90);
    ($oldW, $oldH) = ($oldH, $oldW);
  }elsif($$opts{orientSwap} and not isOrientMatch $oldW, $oldH, $newW, $newH){
    ($newW, $newH) = ($newH, $newW);
  }

  my $percent = getResizePercent $newW, $newH, $oldW, $oldH;
  @args = (@args, "-resize", "$percent%");

  if($percent < $SHARPEN_SIZE_PCT_THRESHOLD){
    @args = (@args, "-unsharp", $UNSHARP_ARG);
  }

  if($$opts{pad}){
    @args = (@args,
      "-gravity", $$opts{padGravity},
      "-background", $$opts{padColor},
      "-extent", "${newW}x${newH}",
    );
  }

  #ensure parent img file dir
  runCmd $opts, "mkdir", "-p", dirname($destImgFile);

  my $success = runConvert $opts, $inputImgFile, $destImgFile, @args;
  if(not $success){
    return 0;
  }

  if(defined $tmpFile){
    runCmd $opts, "rm", $tmpFile;
  }

  #ensure parent info file dir
  runCmd $opts, "mkdir", "-p", dirname($destInfoFile);

  writeInfoFile $opts, $destInfoFile, $statInfo;

  touchByRef $opts, $srcImgFile, $destImgFile;
  touchByRef $opts, $srcImgFile, $destInfoFile;

  my $exifRotateFmt;
  if($exifRotated and $exifAspectSwapped){
    $exifRotateFmt = "?exifTranspose";
  }elsif($exifRotated){
    $exifRotateFmt = "?exifRotate";
  }else{
    $exifRotateFmt = "";
  }

  my $fmt = sprintf "ok|%-15s| %s\n", $exifRotateFmt, $imgName;
  print $fmt;

  return 1;
}

sub getTmpFile($$$){
  my ($tmpDir, $description, $suffix) = @_;

  my $nameFmt = $description;
  $nameFmt =~ s/\.($REGEX_IMG_EXTS)$//;
  $nameFmt =~ s/\W+/_/g;
  $nameFmt =~ s/__+/_/g;
  $nameFmt =~ s/^_//g;
  $nameFmt =~ s/_$//g;

  return "$tmpDir/tmp-" . nowMillis() . "-$nameFmt" . $suffix;
}

sub isOrientMatch($$$$){
  my ($x1, $y1, $x2, $y2) = @_;
  my $orient1 = $x1 > $y1 ? "landscape" : "portrait";
  my $orient2 = $x2 > $y2 ? "landscape" : "portrait";
  return $orient1 eq $orient2;
}

sub getResizePercent($$$$){
  my ($newW, $newH, $oldW, $oldH) = @_;
  my $ratio;

  my $ratio1 = $newW / $oldW;
  my $ratio2 = $newH / $oldH;
  $ratio = $ratio1 < $ratio2 ? $ratio1 : $ratio2;

  my $percent = sprintf '%.5f', $ratio*100;

  return $percent;
}

sub runConvert($$$@){
  my ($opts, $inputFile, $outputFile, @args) = @_;

  runCmd $opts, $EXEC_CONVERT, $inputFile, @args, $outputFile;
  if($? == 0){
    return 1;
  }else{
    print "\n\n\n\nCONVERT FAILED: $inputFile {@args}\n\n\n\n";
    return 0;
  }
}

sub readFile($){
  my ($file) = @_;
  if(not -e $file){
    return undef;
  }
  open my $fh, "< $file" or die "ERROR: could not read $file\n$!\n";
  my @lines = <$fh>;
  close $fh;

  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;
  }
}
sub writeFile($$$){
  my ($opts, $file, $contents) = @_;
  if($$opts{simulate}){
    print "#write: $file\n";
  }else{
    open my $fh, "> $file" or die "ERROR: could not write $file\n$!\n";
    print $fh $contents;
    close $fh;
  }
}

sub readProc(@){
  my (@cmd) = @_;
  open my $cmdH, "-|", @cmd or die "ERROR: could not run @cmd\n$!\n";
  my @lines = <$cmdH>;
  close $cmdH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;
  }
}

sub runCmd($@){
  my ($opts, @cmd) = @_;
  if($$opts{simulate}){
    print "#@cmd\n";
  }else{
    system @cmd;
  }
}

sub ipcRunCmd($@){
  my ($opts, @cmd) = @_;
  if($$opts{simulate}){
    print "#@cmd\n";
    return {out=>"", err=>"", success=>1};
  }else{
    my ($out, $err);
    my $success = run [@cmd], '>', \$out, '2>', \$err;
    return {out=>$out, err=>$err, success=>$success};
  }
}

sub nowMillis(){
  return int(time*1000.0 + 0.5);
}

&main(@ARGV);
