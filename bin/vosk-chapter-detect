#!/usr/bin/perl
use strict;
use warnings;
use Cpanel::JSON::XS qw();
use File::Basename qw(basename);
use Lingua::EN::Words2Nums qw(words2nums);

sub readPosIntFromText($);
sub readFileDecompressed($);

my $EXEC = basename $0;

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC VOSK_JSON_FILE [VOSK_JSON_FILE ..]
    parse json for sentences that look like chapter/part/section starts
    does not output *any* parsed text (no spoilers)

      -for each VOSK_JSON_FILE:
        -find CHAPTER_ENTRY items:
          -for each sentence TEXT:
            -get START_TIME_FRAC_S of first word start time in file in vosk json
            -parse TEXT into FIRST_WORD and OTHER_WORDS
            -if FIRST_WORD is 'chapter':
              -take OTHER_WORDS as POSSIBLE_INT_STRING
              -try to parse POSSIBLE_INT_STRING as an integer NUM with Lingua::EN:Words2Nums
              -if NUM is found:
                -add a CHAPTER_ENTRY with CHAPTER_ID='ch<NUM>'
        -for each CHAPTER_ENTRY:
          -output one per line, formatted:
            <VOSK_JSON_FILE>:<START_TIME_FRAC_S>:<CHAPTER_ID>

    VOSK_JSON_FILE
      -file containing word-timings JSON output produced by vosk.KaldiRecognizer
        (e.g.: from `vosk-words-json`)
      -can be gz or xz compressed
";

sub main(@){
  my @voskJsonFiles;
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif(-f $arg){
      push @voskJsonFiles, $arg;
    }else{
      die "ERROR: unknown arg $arg\n";
    }
  }

  for my $jsonFile(@voskJsonFiles){
    my $jsonText = readFileDecompressed($jsonFile);
    my $jsonObj = Cpanel::JSON::XS->new->utf8->decode($jsonText);
    for my $res(@$jsonObj){
      my @wordsArr = @{$$res{result}};
      next if @wordsArr == 0;

      my %firstWordEntry = %{$wordsArr[0]};
      my $firstWord = $firstWordEntry{word};
      my $firstWordStartTime = $firstWordEntry{start};

      my $chName = undef;
      if($firstWord eq "chapter"){
        my $suffix = join " ", map {$$_{word}} @wordsArr[1..$#wordsArr];
        my $num = readPosIntFromText($suffix);
        if(defined $num){
          $chName = "ch$num";
        }
      }

      if(defined $chName){
        print "$chName:$jsonFile:$firstWordStartTime\n";
      }
    }
  }
}

sub readPosIntFromText($){
  my ($text) = @_;
  my $num = words2nums($text);
  if(defined $num and ($num < 0 or $num !~ /^\d+$/)){
    $num = undef;
  }
  return $num;
}

sub readFileDecompressed($){
  my ($file) = @_;
  my @cmd;
  if($file =~ /\.gz$/i){
    @cmd = ("gzip", "-d", "--stdout", $file);
  }elsif($file =~ /\.xz/i){
    @cmd = ("xz", "-d", "--stdout", $file);
  }else{
    @cmd = ("cat", $file);
  }
  open my $cmdH, "-|", @cmd or die "ERROR: '@cmd' failed\n$!\n";
  my @lines = <$cmdH>;
  close $cmdH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;
  }
}

&main(@ARGV);
