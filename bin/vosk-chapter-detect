#!/usr/bin/perl
use strict;
use warnings;
use Cpanel::JSON::XS qw();
use File::Basename qw(basename);

sub readFileDecompressed($);

my $EXEC = basename $0;

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC VOSK_JSON_FILE [VOSK_JSON_FILE ..]
    parse json for sentences that look like chapter/part/section starts
    does not output *any* parsed text (no spoilers)

    VOSK_JSON_FILE
      -file containing word-timings JSON output produced by vosk.KaldiRecognizer
        (e.g.: from `vosk-words-json`)
      -can be gz or xz compressed
";

sub main(@){
  my @voskJsonFiles;
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif(-f $arg){
      push @voskJsonFiles, $arg;
    }else{
      die "ERROR: unknown arg $arg\n";
    }
  }

  for my $jsonFile(@voskJsonFiles){
    my $jsonText = readFileDecompressed($jsonFile);
    my $jsonObj = Cpanel::JSON::XS->new->utf8->decode($jsonText);
    for my $res(@$jsonObj){
      my @wordsArr = @{$$res{result}};
      next if @wordsArr == 0;

      my %firstWordEntry = %{$wordsArr[0]};
      my $firstWord = $firstWordEntry{word};
      my $firstWordStartTime = $firstWordEntry{start};

      if($firstWord eq "chapter"){
        print "$jsonFile:$firstWordStartTime\n";
      }
    }
  }
}

sub readFileDecompressed($){
  my ($file) = @_;
  my @cmd;
  if($file =~ /\.gz$/i){
    @cmd = ("gzip", "-d", "--stdout", $file);
  }elsif($file =~ /\.xz/i){
    @cmd = ("xz", "-d", "--stdout", $file);
  }else{
    @cmd = ("cat", $file);
  }
  open my $cmdH, "-|", @cmd or die "ERROR: '@cmd' failed\n$!\n";
  my @lines = <$cmdH>;
  close $cmdH;
  if(wantarray){
    return @lines;
  }else{
    return join '', @lines;
  }
}

&main(@ARGV);
