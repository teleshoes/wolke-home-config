#!/usr/bin/perl
use strict;
use warnings;
use File::Basename qw(basename);

my $EXEC = basename $0;

my $DEFAULT_TIMEOUT_S = 5;

my $USAGE = "Usage:
  $EXEC -h|--help
    show this message

  $EXEC [OPTS] MAC [MAC MAC..]
    wrapper around bluetoothctl and expect
    run bluetoothctl 'scan on' for at most TIMEOUT_S and print the first MAC that appears
      -print 'FOUND=<MAC>' for the first one found
      -print 'NONE' if no device is not found

  OPTS
    -t TIMEOUT_S | --timeout TIMEOUT_S | --timeout=TIMEOUT_S
      wait at most TIMEOUT_S, 0 for forever
      default = $DEFAULT_TIMEOUT_S

    -v | --verbose
      print bluetoothctl output

    --le | --ble
      use 'scan le' in bluetoothctl scan for bluetooth low energy
    --no-ble
      use 'scan on' in bluetoothctl
      (this is the default)
";

sub main(@){
  my $opts = {
    timeout => $DEFAULT_TIMEOUT_S,
    verbose => 0,
    ble     => 0,
  };
  my @macs;
  my $h2 = "[0-9a-f][0-9a-f]";
  while(@_ > 0){
    my $arg = shift;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(-t|--timeout)$/ and @_ > 0 and $_[0] =~ /^\d+$/){
      $$opts{timeout} = shift @_;
    }elsif($arg =~ /^--timeout=(\d+)$/){
      $$opts{timeout} = $1;
    }elsif($arg =~ /^(-v|--verbose)$/){
      $$opts{verbose} = 1;
    }elsif($arg =~ /^(--le|--ble)$/){
      $$opts{ble} = 1;
    }elsif($arg =~ /^(--no-ble)$/){
      $$opts{ble} = 0;
    }elsif($arg =~ /^($h2:$h2:$h2:$h2:$h2:$h2)$/i){
      push @macs, uc $arg;
    }else{
      die "ERROR: unknown arg $arg\n";
    }
  }

  die "ERROR: MAC is required\n" if @macs == 0;

  my $scanMode = $$opts{ble} ? "le" : "on";
  my $deviceRegex = "(?:CHG|NEW)\\S* Device (" . join("|", @macs) . ")";

  my $logUserVal = $$opts{verbose} ? 1 : 0;

  my $expectScript = ""
    . "log_user $logUserVal\n"
    . "spawn bluetoothctl\n"
    . "send -- \"scan $scanMode\\r\"\n"
    . "expect"
    . " -timeout $$opts{timeout}"
    . " -re {$deviceRegex}"
    . " {puts \"FOUND=\$expect_out(1,string)\"}"
    . " timeout {puts \"NONE\"}"
    . "\n"
    . "send -- \"scan off\\r\"\n"
    . "send -- \"exit\\r\"\n"
  ;

  exec "expect", "-c", $expectScript;
}

&main(@ARGV);
