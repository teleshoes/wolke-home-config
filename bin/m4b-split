#!/usr/bin/perl
use strict;
use warnings;
use POSIX qw(ceil);

sub getConvertCmds($$@);
sub parseChapterInfo($);

my $DEFAULT_CHUNK_PERCENT = 20;

my $USAGE = "Usage:
  $0 -h | --help
    show this message

  $0 [OPTS] M4B_FILE
    losslessly split M4B file into M4A chapters with ffmpeg

  OPTS
    --prefix=PREFIX
      output files will be named: <PREFIX>_<CHAPTER_NUMBER>_<CHAPTER_TITLE_NAME>.m4a
      default is M4B_FILE, with the file extension '.m4b' removed

    -n | -s | --simulate | --dry-run
      print ffmpeg conversion commands without running them

    --chunk-size=CHUNK_SIZE
      limit each ffmpeg command to a maximum of CHUNK_SIZE chapter output files
      '0' means no limit
        (the default is --chunk-percent=$DEFAULT_CHUNK_PERCENT)

    --chunk-percent=CHUNK_PERCENT
      -calculate CHAPTER_COUNT from M4B file
      -calculate CHUNK_SIZE = ceiling(CHUNK_SIZE * CHUNK_PERCENT / 100)
      -same as: --chunk-size=CHUNK_SIZE
        (the default is --chunk-percent=$DEFAULT_CHUNK_PERCENT)

    --ffmpeg-default
      -same as: --chunk-percent=$DEFAULT_CHUNK_PERCENT
        -this is the default
        -$DEFAULT_CHUNK_PERCENT% of files handled by each ffmpeg command
        -M4B is redundantly decoded, but only up to "
          . ceil(100.0/$DEFAULT_CHUNK_PERCENT) . "x in total
        -M4A files are fully finished in batches of $DEFAULT_CHUNK_PERCENT% chapters

    --ffmpeg-multi
      same as: --chunk-size=0
        -a single, possibly very long, ffmpeg cmd handles all chapters at once
        -M4B file is decoded exactly once, writing the data to each output as it goes
        -M4A files are not finished until the end, when all of the decoded data is written

    --ffmpeg-single
      same as: --chunk-size=1
        -each ffmpeg command handles exactly one chapter
        -M4B file is redundantly decoded up to the beginning of each chapter
        -M4A files are fully written before the next chapter is started
";

sub main(@){
  my $m4bFile = undef;
  my $opts = {
    prefix       => undef,
    dryRun       => 0,
    chunkSize    => undef,
    chunkPercent => undef,
  };
  while(@_ > 0){
    my $arg = shift @_;
    if($arg =~ /^(-h|--help)$/){
      print $USAGE;
      exit 0;
    }elsif($arg =~ /^(-n|-s|--simulate|--dry-run)$/){
      $$opts{dryRun} = 1;
    }elsif($arg =~ /^--chunk-size=(\d+)$/){
      $$opts{chunkSize} = $1;
      $$opts{chunkPercent} = undef;
    }elsif($arg =~ /^--chunk-percent=(\d+)$/){
      $$opts{chunkSize} = undef;
      $$opts{chunkPercent} = $1;
    }elsif($arg =~ /^(--ffmpeg-default)$/){
      $$opts{chunkSize} = undef;
      $$opts{chunkPercent} = $DEFAULT_CHUNK_PERCENT;
    }elsif($arg =~ /^(--ffmpeg-multi)$/){
      $$opts{chunkSize} = 1;
      $$opts{chunkPercent} = undef;
    }elsif($arg =~ /^(--ffmpeg-single)$/){
      $$opts{chunkSize} = 0;
      $$opts{chunkPercent} = undef;
    }elsif(-f $arg and not defined $m4bFile){
      $m4bFile = $arg;
    }else{
      die "$USAGE\nERROR: unknown arg $arg\n";
    }
  }

  die "ERROR: missing M4B_FILE\n" if not defined $m4bFile;
  die "ERROR: M4B_FILE \"$m4bFile\" must end in .m4b\n" if $m4bFile !~ /\.m4b$/i;

  my @chapters = parseChapterInfo($m4bFile);
  my $chNumLen = length (0+@chapters);
  my $chNum = 1;

  my @outputs;

  for my $ch(@chapters){
    my $titleFmt = $$ch{title};
    $titleFmt =~ s/'//g;
    $titleFmt = lc $titleFmt;
    $titleFmt =~ s/\W+/_/g;
    my $chNumFmt = sprintf "%0${chNumLen}d", $chNum;
    $chNum++;

    my $destFile = undef;
    if(defined $$opts{prefix}){
      $destFile = $$opts{prefix};
    }else{
      $destFile = $m4bFile;
      $destFile =~ s/\.m4b$//;
    }
    $destFile .= "_${chNumFmt}_${titleFmt}.m4a";
    push @outputs, {
      destFile  => $destFile,
      startTime => $$ch{startTime},
      endTime   => $$ch{endTime},
    };
  }

  my $chunkSize;
  if(defined $$opts{chunkSize}){
    $chunkSize = $$opts{chunkSize};
  }else{
    my $chunkPct = $$opts{chunkPercent};
    $chunkPct = $DEFAULT_CHUNK_PERCENT if not defined $chunkPct;
    $chunkSize = ceil(@chapters * $chunkPct / 100.0)
  }

  my @convertCmds = getConvertCmds($m4bFile, $chunkSize, @outputs);

  for my $cmd(@convertCmds){
    if($$opts{dryRun}){
      print "#@$cmd\n";
    }else{
      print "@$cmd\n";
      system @$cmd;
    }
  }
}

sub getConvertCmds($$@){
  my ($inputFile, $chunkSize, @outputs) = @_;

  my @cmds;

  my @cmdPrefix = ("ffmpeg",
    "-bitexact",
    "-i", $inputFile,
  );

  my $curCmd = undef;

  my $curCount = 0;
  for my $output(@outputs){
    if(not defined $curCmd){
      $curCmd = [@cmdPrefix];
      push @cmds, $curCmd;
    }

    my @outputArgs = (
      "-c:a", "copy",
      "-vn",
      "-ss", $$output{startTime},
      "-to", $$output{endTime},
      "-bitexact",
      $$output{destFile},
    );

    push @$curCmd, $_ foreach @outputArgs;
    $curCount++;

    if($chunkSize > 0 and $curCount >= $chunkSize){
      $curCmd = undef;
      $curCount = 0;
    }
  }

  return @cmds;
}

sub parseChapterInfo($){
  my ($m4bFile) = @_;
  $m4bFile =~ s/'/'\\''/g;
  my @infoLines = `ffmpeg -i '$m4bFile' 2>&1`;
  my @chapters;
  my $curChapter = undef;
  for my $line(@infoLines){
    if($line =~ /^    Chapter #(\d+):(\d+): start (\d+|\d*\.\d+), end (\d+|\d*\.\d+)\s*$/){
      $curChapter = {
        streamIdx  => $1,
        chapterIdx => $2,
        startTime  => $3,
        endTime    => $4,
        title      => undef,
      };
      push @chapters, $curChapter;
    }elsif($line =~ /^        title\s*:\s*(.+)$/){
      my $title = $1;
      if(defined $curChapter and not defined $$curChapter{title}){
        $$curChapter{title} = $title;
      }
    }
  }
  return @chapters;
}

&main(@ARGV);
